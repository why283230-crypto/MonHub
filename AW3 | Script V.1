-- ตรวจสอบ Place ID
if game.PlaceId ~= 18923620224 then return end

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
   Name = "AW3 | Enil farm",
   LoadingTitle = "Loading Script...",
   ConfigurationSaving = { Enabled = true, FolderName = "AW3_EnilFarm_Config", FileName = "Settings" }
})

local Tab = Window:CreateTab("Farm", 4483362458)
local WebhookTab = Window:CreateTab("Webhook", 4483362458)

-- Global Variables
_G.WebhookURL = ""
_G.DiscordUserID = ""
_G.AutoFarmBest = false

-- [Function] เช็คสถานะและสร้างข้อความ Log
local function getStatusMessage(isError)
    local status = isError and "❌" or "✅"
    local farmStatus = _G.AutoFarmBest and "✅" or "❌"
    local workStatus = (_G.AutoFarmBest and not isError) and "✅" or "❌"
    
    return string.format(
        "Anime Warriors 3 👾\nStatus %s\nAuto Best Farm %s\nWork %s",
        status, farmStatus, workStatus
    )
end

-- [Function] ส่งข้อมูลไป Discord
local function SendWebhook(msg, mention)
    if _G.WebhookURL == "" or _G.WebhookURL == nil then return end
    local content = (mention and _G.DiscordUserID ~= "") and "<@".._G.DiscordUserID.."> " .. msg or msg
    local data = {
        ["content"] = content,
        ["embeds"] = {{
            ["title"] = "AW3 Farm Status Update",
            ["description"] = msg,
            ["color"] = mention and 16711680 or 65280,
            ["fields"] = {
                {["name"] = "Player", ["value"] = game.Players.LocalPlayer.Name, ["inline"] = true},
                {["name"] = "Server Time", ["value"] = os.date("%X"), ["inline"] = true}
            },
            ["footer"] = { ["text"] = "Delta Executor User" },
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    pcall(function()
        local http = game:GetService("HttpService")
        local json = http:JSONEncode(data)
        if request then
            request({Url = _G.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = json})
        else
            http:PostAsync(_G.WebhookURL, json)
        end
    end)
end

-- [Webhook Loop] ส่งสถานะทุก 10 นาที
task.spawn(function()
    while true do
        if _G.WebhookURL ~= "" and _G.AutoFarmBest then
            SendWebhook(getStatusMessage(false), false)
        end
        task.wait(600) -- 10 นาที
    end
end)

-- [Detection] ตรวจสอบถ้าหลุดเกม
game:GetService("CoreGui").ChildAdded:Connect(function(child)
    if child.Name == "ErrorPrompt" then
        SendWebhook("⚠️ **PLAYER DISCONNECTED!**\n" .. getStatusMessage(true), true)
    end
end)

-- [Function] ค้นหาศัตรู
local function getEnemy()
    for _, v in pairs(workspace.World.Enemies:GetChildren()) do
        if v:FindFirstChild("HumanoidRootPart") then return v end
    end
    return nil
end

-- --- UI Elements ---

-- Farm Tab
Tab:CreateToggle({
   Name = "Auto Farm Best",
   CurrentValue = false,
   Flag = "FarmBest_Save",
   Callback = function(Value)
      _G.AutoFarmBest = Value
      if Value then 
          task.spawn(function()
              pcall(function()
                  local targetEgg = workspace.World.Map["Sky Island"].Components:GetChildren()[8]
                  if targetEgg then
                      game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = targetEgg:IsA("Model") and targetEgg:GetModelCFrame() or targetEgg.CFrame
                  end
              end)
              task.wait(2)
              pcall(function()
                  local args = {"Sky", true}
                  game:GetService("ReplicatedStorage"):WaitForChild("rbxts_include"):WaitForChild("node_modules"):WaitForChild("@rbxts"):WaitForChild("remo"):WaitForChild("src"):WaitForChild("container"):WaitForChild("eggs.setAuto"):FireServer(unpack(args))
              end)
              while _G.AutoFarmBest do
                  local enemy = getEnemy() 
                  if enemy and enemy:FindFirstChild("HumanoidRootPart") then
                      game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = enemy.HumanoidRootPart.CFrame
                  end
                  game:GetService("RunService").Heartbeat:Wait()
              end
          end)
          SendWebhook("🚀 **Started Auto Best Farm**\n" .. getStatusMessage(false), false)
      end
   end,
})

