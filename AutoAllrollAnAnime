-- [[ 1. NEW WEBHOOK LOGIC (ยกชุดจากที่พี่ส่งมา) ]]
local webhookURL = "ใส่ของตัวเอง" -- จะถูกทับด้วยค่าจาก UI
local purchaseQueue = {}
local isWaiting = false

local function formatNumber(n)
    n = tonumber(n) or 0
    if n == 0 then return "0" end
    local s = {"", "K", "M", "B", "T", "Q", "Qi", "Sx", "Sp", "Oc", "No", "Dc"}
    local i = math.floor(math.log10(math.abs(n))/3)
    if i < 1 then return tostring(math.floor(n)) end
    return string.format("%.2f%s", n/10^(i*3), s[i+1]):gsub("%.00", "")
end

local function sendSummaryLog()
    task.wait(0.5) 
    local sortedList = {}
    for name, data in pairs(purchaseQueue) do
        table.insert(sortedList, {
            name = name,
            bought = data.bought,
            totalStock = data.instance.Value
        })
    end

    -- เรียงลำดับจาก สต็อกรวมน้อย -> มาก
    table.sort(sortedList, function(a, b) return a.totalStock < b.totalStock end)

    local report = ""
    for i, data in ipairs(sortedList) do
        report = report .. string.format("%d. **%s**: `+%s` | รวม: `%s`\n", i, data.name, formatNumber(data.bought), formatNumber(data.totalStock))
    end

    if report == "" or webhookURL == "" or webhookURL == "ใส่ของตัวเอง" then isWaiting = false return end

    local payload = HttpService:JSONEncode({
        ["embeds"] = {{
            ["title"] = "📦 MonHub | รายงานสต็อก (น้อย ➔ มาก)",
            ["description"] = report,
            ["color"] = 16733952,
            ["footer"] = {["text"] = "Player: " .. player.Name},
            ["timestamp"] = DateTime.now():ToIsoDate()
        }}
    })

    local request = (syn and syn.request) or (http and http.request) or http_request or (Fluxus and Fluxus.request)
    if request then
        request({Url = webhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload})
    else
        pcall(function() HttpService:PostAsync(webhookURL, payload) end)
    end
    purchaseQueue = {}
    isWaiting = false
end

-- [[ ระบบตรวจจับ (ใช้ Logic พี่ 100%) ]]
task.spawn(function()
    while true do
        for _, v in ipairs(player:GetDescendants()) do
            if v:IsA("ValueBase") and v.Name:lower():find("block") then
                if not v:GetAttribute("MonMonitored") then
                    v:SetAttribute("MonMonitored", true)
                    local lastValue = v.Value
                    v.Changed:Connect(function(newValue)
                        if newValue > lastValue then
                            local diff = newValue - lastValue
                            if not purchaseQueue[v.Name] then
                                purchaseQueue[v.Name] = {bought = 0, instance = v}
                            end
                            purchaseQueue[v.Name].bought = purchaseQueue[v.Name].bought + diff
                            if not isWaiting then
                                isWaiting = true
                                task.delay(2, sendSummaryLog)
                            end
                        end
                        lastValue = newValue
                    end)
                end
            end
        end
        task.wait(5)
    end
end)

