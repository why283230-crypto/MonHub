local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MonHub | Block Master V6.2",
   LoadingTitle = "Checking All Functions...",
   LoadingSubtitle = "Everything is here! | Speed: 0.05s",
   ConfigurationSaving = { Enabled = false }
})

-- [[ DATA LISTS ]]
local SortedBlocks = {
    "CommonBlock", "UncommonBlock", "RareBlock", "EpicBlock", "LegendaryBlock",
    "MythicBlock", "GalaxyBlock", "QuantumBlock", "AscendantBlock", "DevilBlock",
    "HeavenlyBlock", "MagicBlock", "BrambleBlock", "TimeBenderBlock", "InfinityBlock",
    "KingSunBlock", "OuroborosBlock", "MoltenCoreBlock", "ToxicReactorBlock", "KingsMantleBlock",
    "TheEndBlock", "AetherialBlock", "RadiantBlock", "CelestialEmperorBlock", "PhantomBlock",
    "AnomalyBlock", "VercaBlock", "VortexBlock", "BloodcodeBlock", "DoomBlock",
    "HellcoreBlock", "VerdictBlock", "PinnacleBlock"
}

local PetEggs = { "Basic", "Coconut", "Crocodile", "Yeti", "Cupcake", "GoldenBasic" }

-- Variables
local SelectedRoll = ""
local SelectedBuyList = {}
local SelectedPlot = "1"
local SelectedEgg = ""
local CurrentLock = nil

-- ==========================================
-- [[ Tab 1: Roll & Buy ]]
-- ==========================================
local MainTab = Window:CreateTab("Roll & Buy", 4483362458)

-- 1.1 Smart Focus (ระบบสุ่มอันเทพสุดที่มีจริง)
MainTab:CreateSection("Smart Focus Roll")
MainTab:CreateToggle({
   Name = "Smart Roll (Lock Real Best)",
   CurrentValue = false,
   Callback = function(Value)
      _G.SmartLock = Value
      if not Value then
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(false) end)
         CurrentLock = nil
         return
      end
      task.spawn(function()
         while _G.SmartLock do
            local foundBest = nil
            for i = #SortedBlocks, 1, -1 do
               if not _G.SmartLock then break end
               local target = SortedBlocks[i]
               local success = pcall(function()
                  return game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(target)
               end)
               if success then
                  foundBest = target
                  break 
               end
            end
            if foundBest and foundBest ~= CurrentLock then
               CurrentLock = foundBest
               pcall(function()
                  game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true)
               end)
               Rayfield:Notify({Title = "Locked!", Content = "ล็อคเป้า: " .. foundBest, Duration = 3})
            end
            task.wait(5)
         end
      end)
   end,
})

-- 1.2 Manual Roll
MainTab:CreateSection("Manual Roll")
MainTab:CreateDropdown({
   Name = "Select Block to Roll",
   Options = SortedBlocks,
   CurrentOption = "",
   MultipleOptions = false,
   Callback = function(Option) SelectedRoll = Option[1] end,
})
MainTab:CreateToggle({
   Name = "Auto Roll Selected",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoRoll = Value
      while _G.AutoRoll do
         if SelectedRoll ~= "" then
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(SelectedRoll) end)
         end
         task.wait(0.05)
      end
   end,
})

-- 1.3 Auto Buy (เช็คแล้ว: อยู่ครบทั้ง Buy All และ Multi-Select)
MainTab:CreateSection("Auto Buy Systems")
MainTab:CreateToggle({
   Name = "Auto Buy ALL List (ทุกบล็อก)",
   CurrentValue = false,
   Callback = function(Value)
      _G.BuyAll = Value
      while _G.BuyAll do
         for _, itemName in pairs(SortedBlocks) do
            if not _G.BuyAll then break end
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(itemName, 999) end)
         end
         task.wait(0.1)
      end
   end,
})
MainTab:CreateDropdown({
   Name = "Multi-Select Buy",
   Options = SortedBlocks,
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options) SelectedBuyList = Options end,
})
MainTab:CreateToggle({
   Name = "Auto Buy Max (Selected)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoBuyMax = Value
      while _G.AutoBuyMax do
         for _, itemName in pairs(SelectedBuyList) do
            if not _G.AutoBuyMax then break end
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(itemName, 999) end)
         end
         task.wait(0.05)
      end
   end,
})

