local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MonHub | Block Master V5.9",
   LoadingTitle = "Player Data Locking...",
   LoadingSubtitle = "Scanning Best Block in Inventory",
   ConfigurationSaving = { Enabled = false }
})

-- [[ DATA: 33 Blocks Verified ]]
local SortedBlocks = {
    "CommonBlock", "UncommonBlock", "RareBlock", "EpicBlock", "LegendaryBlock",
    "MythicBlock", "GalaxyBlock", "QuantumBlock", "AscendantBlock", "DevilBlock",
    "HeavenlyBlock", "MagicBlock", "BrambleBlock", "TimeBenderBlock", "InfinityBlock",
    "KingSunBlock", "OuroborosBlock", "MoltenCoreBlock", "ToxicReactorBlock", "KingsMantleBlock",
    "TheEndBlock", "AetherialBlock", "RadiantBlock", "CelestialEmperorBlock", "PhantomBlock",
    "AnomalyBlock", "VercaBlock", "VortexBlock", "BloodcodeBlock", "DoomBlock",
    "HellcoreBlock", "VerdictBlock", "PinnacleBlock"
}

local PetEggs = { "Basic", "Coconut", "Crocodile", "Yeti", "Cupcake", "GoldenBasic" }

-- Variables
local SelectedRoll = ""
local SelectedBuyList = {}
local SelectedPlot = "1"
local SelectedEgg = ""
local CurrentLock = nil

-- ==========================================
-- [[ Tab 1: Roll & Buy ]]
-- ==========================================
local MainTab = Window:CreateTab("Roll & Buy", 4483362458)

-- 1.1 SMART FOCUS (ล็อคจากข้อมูลในตัวผู้เล่น)
MainTab:CreateSection("Smart Focus (ล็อคอันที่เทพที่สุดในตัว)")
MainTab:CreateToggle({
   Name = "Smart Roll (Lock Inventory Best)",
   CurrentValue = false,
   Callback = function(Value)
      _G.SmartLock = Value
      
      if not Value then
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(false) end)
         CurrentLock = nil
         return
      end

      task.spawn(function()
         while _G.SmartLock do
            local bestInInv = nil
            
            -- ส่องข้อมูลในตัวผู้เล่น (Inventory Scanning)
            pcall(function()
               local playerBlocks = game:GetService("Players").LocalPlayer.Blocks:GetChildren()
               for i = #SortedBlocks, 1, -1 do
                  local targetName = SortedBlocks[i]
                  if game:GetService("Players").LocalPlayer.Blocks:FindFirstChild(targetName) then
                     bestInInv = targetName
                     break
                  end
               end
            end)

            -- ถ้าเจออันที่ดีที่สุด และยังไม่ได้ล็อคอันนี้ไว้
            if bestInInv and bestInInv ~= CurrentLock then
               CurrentLock = bestInInv
               pcall(function()
                  -- 1. เลือกบล็อกที่จะสุ่มก่อน
                  game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(bestInInv)
                  -- 2. เปิดระบบ Auto ของเกมล็อคไว้อันเดียว
                  game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true)
               end)
               
               Rayfield:Notify({
                  Title = "Inventory Lock Updated",
                  Content = "ล็อคเป้าสุ่มบล็อกที่ดีที่สุด: " .. bestInInv,
                  Duration = 3
               })
            end
            task.wait(2) -- วนเช็กข้อมูลในตัวทุก 2 วินาที เผื่อมีการปลดล็อคใหม่
         end
      end)
   end,
})

-- 1.2 MANUAL ROLL (ระบบเดิม)
MainTab:CreateSection("Manual Roll")
MainTab:CreateDropdown({
   Name = "Select Block to Roll",
   Options = SortedBlocks,
   CurrentOption = "",
   MultipleOptions = false,
   Callback = function(Option) SelectedRoll = Option[1] end,
})
MainTab:CreateToggle({
   Name = "Auto Roll Selected",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoRoll = Value
      while _G.AutoRoll do
         if SelectedRoll ~= "" then
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(SelectedRoll) end)
         end
         task.wait(0.05)
      end
   end,
})

-- 1.3 AUTO BUY (ระบบเดิม)
MainTab:CreateSection("Auto Buy")
MainTab:CreateDropdown({
   Name = "Multi-Select Buy",
   Options = SortedBlocks,
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options) SelectedBuyList = Options end,
})
MainTab:CreateToggle({
   Name = "Auto Buy Max (Selected)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoBuyMax = Value
      while _G.AutoBuyMax do
         for _, itemName in pairs(SelectedBuyList) do
            if not _G.AutoBuyMax then break end
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(itemName, 999) end)
         end
         task.wait(0.05)
      end
   end,
})

-- ==========================================
-- [[ Tab 2: Pets ]]
-- ==========================================
local PetTab = Window:CreateTab("Pets", 4483362458)
PetTab:CreateDropdown({
   Name = "Select Egg",
   Options = PetEggs,
   CurrentOption = "",
   MultipleOptions = false,
   Callback = function(Option) SelectedEgg = Option[1] end,
})
PetTab:CreateToggle({
   Name = "Auto Hatch (0.1s)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoHatch = Value
      while _G.AutoHatch do
         if SelectedEgg ~= "" then
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.Hatch:InvokeServer(SelectedEgg, 1) end)
         end
         task.wait(0.1)
      end
   end,
})

-- ==========================================
-- [[ Tab 3: Upgrades ]]
-- ==========================================
local UpTab = Window:CreateTab("Upgrades", 4483362458)
UpTab:CreateInput({
   Name = "Plot Number",
   PlaceholderText = "1",
   Callback = function(Text) SelectedPlot = Text end,
})
UpTab:CreateToggle({
   Name = "Auto Upgrade All Plots (1-100)",
   CurrentValue = false,
   Callback = function(Value)
