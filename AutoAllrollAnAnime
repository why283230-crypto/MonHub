local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MonHub | Block Master V7.1",
   LoadingTitle = "Restoring All Features...",
   LoadingSubtitle = "Every Button is Back!",
   ConfigurationSaving = { Enabled = false }
})

-- [[ DATA LISTS ]]
local SortedBlocks = {
    "CommonBlock", "UncommonBlock", "RareBlock", "EpicBlock", "LegendaryBlock",
    "MythicBlock", "GalaxyBlock", "QuantumBlock", "AscendantBlock", "DevilBlock",
    "HeavenlyBlock", "MagicBlock", "BrambleBlock", "TimeBenderBlock", "InfinityBlock",
    "KingSunBlock", "OuroborosBlock", "MoltenCoreBlock", "ToxicReactorBlock", "KingsMantleBlock",
    "TheEndBlock", "AetherialBlock", "RadiantBlock", "CelestialEmperorBlock", "PhantomBlock",
    "AnomalyBlock", "VercaBlock", "VortexBlock", "BloodcodeBlock", "DoomBlock",
    "HellcoreBlock", "VerdictBlock", "PinnacleBlock"
}

local PetEggs = { "Basic", "Coconut", "Crocodile", "Yeti", "Cupcake", "GoldenBasic" }

-- [[ Global States ]]
local Config = {
    SmartTarget = "KingSunBlock",
    SelectedRoll = "",
    SelectedBuyList = {},
    SelectedEgg = "",
    SelectedPlot = "1"
}

-- ==========================================
-- [[ Tab 1: Roll & Buy ]]
-- ==========================================
local MainTab = Window:CreateTab("Roll & Buy", 4483362458)

-- 1.1 Configurable Smart Roll (ที่คุณเสนอ)
MainTab:CreateSection("Smart Roll (Config Mode)")
MainTab:CreateDropdown({
   Name = "1. Set Smart Target",
   Options = SortedBlocks,
   CurrentOption = "KingSunBlock",
   MultipleOptions = false,
   Callback = function(Option) Config.SmartTarget = Option[1] end,
})
MainTab:CreateToggle({
   Name = "2. Enable Smart Roll Lock",
   CurrentValue = false,
   Callback = function(Value)
      _G.SmartLock = Value
      if not Value then
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(false) end)
         return
      end
      task.spawn(function()
         while _G.SmartLock do
            pcall(function()
               game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(Config.SmartTarget)
               game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true)
            end)
            task.wait(5)
         end
      end)
   end,
})

-- 1.2 Manual Roll
MainTab:CreateSection("Manual Roll")
MainTab:CreateDropdown({
   Name = "Select Block",
   Options = SortedBlocks,
   CurrentOption = "",
   MultipleOptions = false,
   Callback = function(Option) Config.SelectedRoll = Option[1] end,
})
MainTab:CreateToggle({
   Name = "Auto Roll Selected",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoRoll = Value
      while _G.AutoRoll do
         if Config.SelectedRoll ~= "" then
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(Config.SelectedRoll) end)
         end
         task.wait(0.05)
      end
   end,
})

-- 1.3 Auto Buy (กู้คืนครบทุกฟังก์ชัน)
MainTab:CreateSection("Auto Buy Systems")
MainTab:CreateToggle({
   Name = "Auto Buy ALL List (ทุกบล็อก)",
   CurrentValue = false,
   Callback = function(Value)
      _G.BuyAll = Value
      while _G.BuyAll do
         for _, name in pairs(SortedBlocks) do
            if not _G.BuyAll then break end
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(name, 999) end)
         end
         task.wait(0.1)
      end
   end,
})
MainTab:CreateDropdown({
   Name = "Multi-Select Buy",
   Options = SortedBlocks,
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options) Config.SelectedBuyList = Options end,
})
MainTab:CreateToggle({
   Name = "Auto Buy Max (Selected)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoBuyMax = Value
      while _G.AutoBuyMax do
         for _, name in pairs(Config.SelectedBuyList) do
            if not _G.AutoBuyMax then break end
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(name, 999) end)
         end
         task.wait(0.05)
      end
   end,
})

-- ==========================================
-- [[ Tab 2: Pets ]]
-- ==========================================
local PetTab = Window:CreateTab("Pets", 4483362458)
PetTab:CreateDropdown({
   Name = "Select Egg",
   Options = PetEggs,
   CurrentOption = "",
   MultipleOptions = false,
   Callback = function(Option) Config.SelectedEgg = Option[1] end,
})
PetTab:CreateToggle({
   Name = "Auto Hatch (0.1s)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoHatch = Value
      while _G.AutoHatch do
         if Config.SelectedEgg ~= "" then
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.Hatch:InvokeServer(Config.SelectedEgg, 1) end)
         end
         task.wait(0.1)
      end
   end,
})

-- ==========================================
-- [[ Tab 3: Upgrades ]]
-- ==========================================
local UpTab = Window:CreateTab("Upgrades", 4483362458)
UpTab:CreateInput({
   Name = "Enter Plot Number (1-100)",
   PlaceholderText = "1",
   Callback = function(Text) Config.SelectedPlot = Text end,
})
UpTab:CreateToggle({
   Name = "Auto Upgrade Selected Plot",
   CurrentValue = false,
   Callback = function(Value)
      _G.UpSingle = Value
      while _G.UpSingle do
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.UpgradeBrainrot:InvokeServer(Config.SelectedPlot) end)
         task.wait(0.1)
      end
   end,
})
UpTab:CreateToggle({
   Name = "Auto Upgrade ALL Plots (1-100)",
   CurrentValue = false,
   Callback = function(Value)
      _G.UpAll = Value
      while _G.UpAll do
         for i = 1, 100 do
            if not _G.UpAll then break end
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.UpgradeBrainrot:InvokeServer(tostring(i)) end)
         end
         task.wait(0.1)
      end
   end,
})

-- ==========================================
-- [[ Tab 4: Misc ]]
-- ==========================================
local MiscTab = Window:CreateTab("Misc", 4483362458)
MiscTab:CreateToggle({
   Name = "Auto Equip Best",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoEquip = Value
      while _G.AutoEquip do
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.EquipBestEntities:InvokeServer() end)
         task.wait(1)
      end
   end,
})
MiscTab:CreateToggle({
   Name = "Auto Sell (True)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoSellTrue = Value
      while _G.AutoSellTrue do
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.SellAllEntities:InvokeServer(true) end)
         task.wait(1)
      end
   end,
})
MiscTab:CreateToggle({
   Name = "Auto Sell (False)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoSellFalse = Value
      while _G.AutoSellFalse do
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.SellAllEntities:InvokeServer(false) end)
         task.wait(1)
      end
   end,
})

Rayfield:Notify({
    Title = "MonHub V7.1 Loaded",
    Content = "Verified: All Single/All Plot Upgrades & Sell modes are active.",
    Duration = 5
})
