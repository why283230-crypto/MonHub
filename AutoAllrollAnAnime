local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MonHub | Block Master V6.8",
   LoadingTitle = "Probe & Memory System Starting...",
   LoadingSubtitle = "Restoring All 7 Major Functions",
   ConfigurationSaving = { Enabled = false }
})

-- [[ DATA LISTS ]]
local SortedBlocks = {
    "CommonBlock", "UncommonBlock", "RareBlock", "EpicBlock", "LegendaryBlock",
    "MythicBlock", "GalaxyBlock", "QuantumBlock", "AscendantBlock", "DevilBlock",
    "HeavenlyBlock", "MagicBlock", "BrambleBlock", "TimeBenderBlock", "InfinityBlock",
    "KingSunBlock", "OuroborosBlock", "MoltenCoreBlock", "ToxicReactorBlock", "KingsMantleBlock",
    "TheEndBlock", "AetherialBlock", "RadiantBlock", "CelestialEmperorBlock", "PhantomBlock",
    "AnomalyBlock", "VercaBlock", "VortexBlock", "BloodcodeBlock", "DoomBlock",
    "HellcoreBlock", "VerdictBlock", "PinnacleBlock"
}

local PetEggs = { "Basic", "Coconut", "Crocodile", "Yeti", "Cupcake", "GoldenBasic" }

-- State Variables
local SelectedRoll = ""
local SelectedBuyList = {}
local SelectedPlot = "1"
local SelectedEgg = ""
local BestVerifiedBlock = nil

-- ==========================================
-- [[ Tab 1: Roll & Buy ]]
-- ==========================================
local MainTab = Window:CreateTab("Roll & Buy", 4483362458)

-- 1.1 Smart Probe Roll (วิธีใหม่ล่าสุด)
MainTab:CreateSection("Smart Probe System")
MainTab:CreateToggle({
   Name = "Smart Roll (Probe & Lock Best)",
   CurrentValue = false,
   Callback = function(Value)
      _G.SmartProbe = Value
      
      if not Value then
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(false) end)
         BestVerifiedBlock = nil
         return
      end

      task.spawn(function()
         -- ขั้นตอนที่ 1: Probe (หยั่งเชิง) หาบล็อกที่เทพที่สุดที่สุ่มได้จริง
         Rayfield:Notify({Title = "Probing...", Content = "กำลังตรวจสอบสิทธิ์การสุ่มของคุณ...", Duration = 2})
         
         for i = #SortedBlocks, 1, -1 do
            if not _G.SmartProbe then break end
            local target = SortedBlocks[i]
            
            -- ลองสุ่ม 1 ครั้งเพื่อเช็คสิทธิ์ (ใช้ pcall กัน Error)
            local success = pcall(function()
               game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(target)
            end)

            if success then
               BestVerifiedBlock = target
               break -- เจอ KingsunBlock หรืออันที่สุ่มได้จริงแล้ว หยุด Probe ทันที
            end
            task.wait(0.05) -- ป้องกันรัวเกินไปตอน Probe
         end

         -- ขั้นตอนที่ 2: Lock (ล็อคเป้าหมายที่จำไว้)
         if BestVerifiedBlock then
            Rayfield:Notify({Title = "Best Block Verified!", Content = "ล็อคเป้าหมายไปที่: " .. BestVerifiedBlock, Duration = 3})
            while _G.SmartProbe and BestVerifiedBlock do
               pcall(function()
                  -- เลือกบล็อกที่จำไว้
                  game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(BestVerifiedBlock)
                  -- เปิด ToggleAutoRoll ของเกม
                  game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true)
               end)
               task.wait(10) -- ตรวจทานทุก 10 วินาทีว่า Toggle ยังทำงานอยู่
            end
         end
      end)
   end,
})

-- 1.2 Manual Roll (ระบบเดิม)
MainTab:CreateSection("Manual Roll")
MainTab:CreateDropdown({
   Name = "Select Block to Roll",
   Options = SortedBlocks,
   CurrentOption = "",
   MultipleOptions = false,
   Callback = function(Option) SelectedRoll = Option[1] end,
})
MainTab:CreateToggle({
   Name = "Auto Roll Selected",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoRoll = Value
      while _G.AutoRoll do
         if SelectedRoll ~= "" then
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(SelectedRoll) end)
         end
         task.wait(0.05)
      end
   end,
})

-- 1.3 Auto Buy (กู้คืนมาให้ครบแล้วครับ!)
MainTab:CreateSection("Auto Buy Systems")
MainTab:CreateToggle({
   Name = "Auto Buy ALL List (เหมาหมด)",
   CurrentValue = false,
   Callback = function(Value)
      _G.BuyAll = Value
      while _G.BuyAll do
         for _, name in pairs(SortedBlocks) do
            if not _G.BuyAll then break end
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(name, 999) end)
         end
         task.wait(0.1)
      end
   end,
})
MainTab:CreateDropdown({
   Name = "Multi-Select Buy",
   Options = SortedBlocks,
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options) SelectedBuyList = Options end,
})
MainTab:CreateToggle({
   Name = "Auto Buy Max (Selected)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoBuyMax = Value
      while _G.AutoBuyMax do
         for _, name in pairs(SelectedBuyList) do
            if not _G.AutoBuyMax then break end
            pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(name, 999) end)
         end
         task.wait(0.05)
      end
   end,
})

