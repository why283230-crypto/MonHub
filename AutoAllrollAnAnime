local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MonHub | Block Master V5.8",
   LoadingTitle = "Switching to Toggle Logic...",
   LoadingSubtitle = "Mode: Auto-Switch Priority",
   ConfigurationSaving = { Enabled = false }
})

-- [[ DATA LISTS ]]
local SortedBlocks = {
    "CommonBlock", "UncommonBlock", "RareBlock", "EpicBlock", "LegendaryBlock",
    "MythicBlock", "GalaxyBlock", "QuantumBlock", "AscendantBlock", "DevilBlock",
    "HeavenlyBlock", "MagicBlock", "BrambleBlock", "TimeBenderBlock", "InfinityBlock",
    "KingSunBlock", "OuroborosBlock", "MoltenCoreBlock", "ToxicReactorBlock", "KingsMantleBlock",
    "TheEndBlock", "AetherialBlock", "RadiantBlock", "CelestialEmperorBlock", "PhantomBlock",
    "AnomalyBlock", "VercaBlock", "VortexBlock", "BloodcodeBlock", "DoomBlock",
    "HellcoreBlock", "VerdictBlock", "PinnacleBlock"
}

local PetEggs = { "Basic", "Coconut", "Crocodile", "Yeti", "Cupcake", "GoldenBasic" }

local CurrentActiveToggle = nil -- เก็บชื่อบล็อกที่กำลังเปิด Auto อยู่

-- ==========================================
-- [[ Tab 1: Roll & Buy ]]
-- ==========================================
local MainTab = Window:CreateTab("Roll & Buy", 4483362458)

MainTab:CreateSection("Smart Toggle Roll (ล็อคอันเทพสุด)")

MainTab:CreateToggle({
   Name = "Smart Auto Roll (Best -> Worst)",
   CurrentValue = false,
   Callback = function(Value)
      _G.SmartToggle = Value
      
      -- ฟังก์ชันสำหรับปิด Auto Roll ที่เปิดค้างไว้
      local function shutOffCurrent()
         if CurrentActiveToggle then
            pcall(function()
               game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(false)
            end)
            CurrentActiveToggle = nil
         end
      end

      if not Value then
         shutOffCurrent()
         return
      end

      task.spawn(function()
         while _G.SmartToggle do
            local bestAvailable = nil
            
            -- 1. หาบล็อกที่ดีที่สุดที่เรา "มีสิทธิ์" สุ่มได้
            for i = #SortedBlocks, 1, -1 do
               local name = SortedBlocks[i]
               if game:GetService("Players").LocalPlayer.Blocks:FindFirstChild(name) then
                  bestAvailable = name
                  break
               end
            end

            -- 2. ถ้าบล็อกที่เทพที่สุด "เปลี่ยนไป" หรือ "ยังไม่ได้เปิด"
            if bestAvailable and bestAvailable ~= CurrentActiveToggle then
               shutOffCurrent() -- ปิดอันเก่าก่อน
               
               -- เลือกบล็อกใหม่ (ต้องเลือกบล็อกก่อนแล้วค่อยกด Toggle)
               pcall(function()
                  -- ส่งคำสั่งเลือกบล็อกเทพที่สุด
                  game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(bestAvailable)
                  -- สั่งเปิด Auto Roll (True)
                  game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true)
               end)
               
               CurrentActiveToggle = bestAvailable
               Rayfield:Notify({
                  Title = "Smart Roll Switched",
                  Content = "Now Focusing: " .. bestAvailable,
                  Duration = 3
               })
            end
            
            -- 3. ระบบตรวจสอบ (ถ้า Auto หลุด หรือเงื่อนไขเปลี่ยน)
            -- เราจะวนเช็กทุกๆ 5 วินาที เพื่อไม่ให้หนักเครื่องเกินไป
            task.wait(5) 
         end
         shutOffCurrent()
      end)
   end,
})

-- ฟังก์ชันอื่นๆ (เหมือนเดิมครบถ้วน)
MainTab:CreateSection("Manual Systems")
