local MainTab = Window:CreateTab("Roll & Buy", 4483362458)

-- 1.1 Smart Waterfall Roll
MainTab:CreateSection("Smart Waterfall Roll (Auto Best)")
MainTab:CreateToggle({
   Name = "Enable Smart Waterfall",
   CurrentValue = false,
   Callback = function(Value)
      _G.SmartRollActive = Value
      StatusFrame.Visible = Value
      if not Value then
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(false) end)
         return
      end

      task.spawn(function()
         while _G.SmartRollActive do
            local player = game:GetService("Players").LocalPlayer
            local inventory = player.PlayerGui:FindFirstChild("Main") 
                and player.PlayerGui.Main:FindFirstChild("DiceContainer")
                and player.PlayerGui.Main.DiceContainer:FindFirstChild("Inventory")
                and player.PlayerGui.Main.DiceContainer.Inventory:FindFirstChild("Scroll")

            local bestFound = "None"
            
            for _, blockName in ipairs(PriorityList) do
               if not _G.SmartRollActive then break end
               ScanStatus.Text = "🔍 Scanning: " .. blockName
               
               local isAvailable = false
               if inventory then
                  local uiItem = inventory:FindFirstChild(blockName)
                  if uiItem then
                     local lockOverlay = uiItem:FindFirstChild("Locked") 
                     if uiItem.Visible == true and (not lockOverlay or lockOverlay.Visible == false) then
                        isAvailable = true
                     end
                  end
               end

               if isAvailable then
                  bestFound = blockName
                  pcall(function()
                     game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(blockName)
                     game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true)
                  end)
                  break
               end
               task.wait(0.01) -- เพื่อให้เห็นการ Scan แบบ Real-time
            end
            MainStatus.Text = "✅ Locked: " .. bestFound
            task.wait(0.1)
         end
      end)
   end,
})

-- 1.2 Manual Roll (สุ่มแบบปกติ)
MainTab:CreateSection("Manual Roll (Normal)")
MainTab:CreateDropdown({
   Name = "Select Block to Roll",
   Options = PriorityList,
   CurrentOption = "",
   MultipleOptions = false,
   Callback = function(Option) Config.ManualTarget = Option[1] end,
})
MainTab:CreateToggle({
   Name = "Auto Roll Manual",
   CurrentValue = false,
   Callback = function(Value)
      _G.ManualRoll = Value
      while _G.ManualRoll do
         if Config.ManualTarget ~= "" then
            pcall(function() 
               game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(Config.ManualTarget)
               game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true)
            end)
         end
         task.wait(0.1)
      end
   end,
})

