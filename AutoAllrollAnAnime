-- ==========================================
-- [[ Tab 1: Roll & Buy ]]
-- ==========================================
local MainTab = Window:CreateTab("Roll & Buy", 4483362458)

-- 1.1 Smart Roll (Fast & Fallback)
MainTab:CreateSection("Smart Roll (Fast Fallback)")
MainTab:CreateDropdown({
   Name = "Set Max Target",
   Options = SortedBlocks,
   CurrentOption = "KingSunBlock",
   MultipleOptions = false,
   Callback = function(Option) Config.SmartTarget = Option[1] end,
})
MainTab:CreateToggle({
   Name = "Enable Fast Smart Roll (0.1s)",
   CurrentValue = false,
   Callback = function(Value)
      _G.SmartLock = Value
      if not Value then
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(false) end)
         return
      end
      task.spawn(function()
         while _G.SmartLock do
            local targetIndex = 1
            for i, name in ipairs(SortedBlocks) do
               if name == Config.SmartTarget then targetIndex = i break end
            end

            -- ระบบ Fallback: วนลูปจากเป้าหมายลงไปหาบล็อกที่กากกว่า
            for i = targetIndex, 1, -1 do
               if not _G.SmartLock then break end
               local currentBlock = SortedBlocks[i]
               local success = pcall(function()
                  game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(currentBlock)
               end)

               if success then
                  pcall(function() game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true) end)
                  break 
               end
            end
            task.wait(0.1) 
         end
      end)
   end,
})

-- 1.2 Manual Roll
MainTab:CreateSection("Manual Roll")
MainTab:CreateDropdown({
   Name = "Select Block",
