local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Pro Script | Ultimate OG Edition",
   LoadingTitle = "All-In-One System",
   LoadingSubtitle = "by Gemini Pro Writer",
   ConfigurationPath = "ProConfig"
})

local MainTab = Window:CreateTab("Main Features", 4483362458)
local UpgradeTab = Window:CreateTab("Upgrades", 4483362458)

-- [ ฟังก์ชันพื้นฐาน ] --
local function warpBehind(target)
    local lp = game.Players.LocalPlayer
    if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        local targetCFrame = target:IsA("Model") and target:GetPivot() or target.CFrame
        local backPos = targetCFrame * CFrame.new(0, 0, 3) 
        hrp.CFrame = backPos
    end
end

-- [ หมวด Main Features ] --

-- 1. ปุ่มวาร์ปไป Mythical Zone (Index 12)
MainTab:CreateButton({
   Name = "Mythical Zone Goto",
   Callback = function()
       local rarityParts = workspace:FindFirstChild("RarityParts")
       if rarityParts then
           local target = rarityParts:GetChildren()[12]
           if target and game.Players.LocalPlayer.Character then
               local targetCFrame = target:IsA("Model") and target:GetPivot() or target.CFrame
               game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = targetCFrame + Vector3.new(0, 5, 0)
           end
       end
   end,
})

-- 2. ระบบ Auto Warp Behind & Grab (ด่าน 17 & 18)
MainTab:CreateToggle({
   Name = "Auto Warp Behind & Grab (17 & 18)",
   CurrentValue = false,
   Flag = "WarpGrab",
   Callback = function(Value)
       _G.WarpGrab = Value
       task.spawn(function()
           while _G.WarpGrab do
               local rarityParts = workspace:FindFirstChild("RarityParts")
               if rarityParts then
                   for _, idx in pairs({17, 18}) do
                       local zone = rarityParts:GetChildren()[idx]
                       local itemsFolder = zone and zone:FindFirstChild("Items")
                       if itemsFolder then
                           for _, item in pairs(itemsFolder:GetChildren()) do
                               if not _G.WarpGrab then break end
                               warpBehind(item)
                               task.wait(0.1)
                               local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                               if prompt then
                                   prompt.HoldDuration = 0
                                   fireproximityprompt(prompt)
                               end
                               game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("CollectEvent"):FireServer("CollectItem")
                               task.wait(0.1)
                           end
                       end
                   end
               end
               task.wait(0.5)
           end
       end)
   end,
})

-- 3. Claim Unit (Remote Toggle)
MainTab:CreateToggle({
   Name = "Claim Unit (Remote)",
   CurrentValue = false,
   Flag = "ClaimUnit",
   Callback = function(Value)
       _G.ClaimUnit = Value
       task.spawn(function()
           local remote = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("CollectEvent")
           while _G.ClaimUnit do
               remote:FireServer("CollectItem")
               task.wait(0.1)
           end
       end)
   end,
})

-- [ หมวด Upgrades ] --

-- 4. Auto Upgrade Aura (Slot 1-20)
UpgradeTab:CreateToggle({
   Name = "Auto Upgrade Aura (Slot 1-20)",
   CurrentValue = false,
   Flag = "UpgradeAura",
   Callback = function(Value)
       _G.UpgradeAura = Value
       task.spawn(function()
           local remote = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("UpgradeItemEvent")
           local userId = tostring(game.Players.LocalPlayer.UserId)
           while _G.UpgradeAura do
               for i = 1, 20 do
                   if not _G.UpgradeAura then break end
                   local slotName = "Slot" .. i
                   local plotPath = workspace.Plots.PlayerPlots:FindFirstChild(userId)
                   if plotPath then
                       local targetSlot = plotPath.Floor1.Slots:FindFirstChild(slotName)
                       if targetSlot and targetSlot:FindFirstChild("Upgrade") then
                           local upgradeGUI = targetSlot.Upgrade.Part:FindFirstChild("UpgradeGUI")
                           if upgradeGUI then
                               remote:FireServer(upgradeGUI, "NormalUpgrade")
                           end
                       end
                   end
               end
               task.wait(0.5)
           end
       end)
   end,
})

Rayfield:LoadConfiguration()
