local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Monhub | V1.2.1 (Status Log)",
   LoadingTitle = "Warp Behind System",
   LoadingSubtitle = "by Gemini Pro Writer",
   ConfigurationPath = "ProConfig"
})

local MainTab = Window:CreateTab("Auto Warp", 4483362458)
local TradeTab = Window:CreateTab("Trade System", 4483362458)

-- [ สถานะการทำงาน (Log) ] --
local StatusLabel = TradeTab:CreateLabel("Status: Waiting for input...")

-- [ ตัวแปรสำหรับระบบ Trade ] --
local SelectedPlayer = ""

-- [ ฟังก์ชันวาร์ปไปด้านหลัง - ห้ามแก้ตามสั่ง ] --
local function warpBehind(target)
    local lp = game.Players.LocalPlayer
    if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        local targetCFrame = target:IsA("Model") and target:GetPivot() or target.CFrame
        local backPos = targetCFrame * CFrame.new(0, 0, 3) 
        hrp.CFrame = backPos
    end
end

-- [ หมวด Auto Warp (12, 17, 18) - ห้ามแก้ ] --

MainTab:CreateButton({
   Name = "Mythical Zone Goto",
   Callback = function()
       local rarityParts = workspace:FindFirstChild("RarityParts")
       if rarityParts then
           local target = rarityParts:GetChildren()[12]
           if target and game.Players.LocalPlayer.Character then
               local targetCFrame = target:IsA("Model") and target:GetPivot() or target.CFrame
               game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = targetCFrame + Vector3.new(0, 5, 0)
           end
       end
   end,
})

MainTab:CreateToggle({
   Name = "Auto Warp Behind & Grab",
   CurrentValue = false,
   Flag = "WarpGrab",
   Callback = function(Value)
       _G.WarpGrab = Value
       task.spawn(function()
           while _G.WarpGrab do
               local rarityParts = workspace:FindFirstChild("RarityParts")
               if rarityParts then
                   for _, idx in pairs({17, 18}) do
                       local zone = rarityParts:GetChildren()[idx]
                       local itemsFolder = zone and zone:FindFirstChild("Items")
                       if itemsFolder then
                           for _, item in pairs(itemsFolder:GetChildren()) do
                               if not _G.WarpGrab then break end
                               warpBehind(item)
                               task.wait(0.1)
                               local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                               if prompt then
                                   prompt.HoldDuration = 0
                                   fireproximityprompt(prompt)
                               end
                               game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("CollectEvent"):FireServer("CollectItem")
                               task.wait(0.1)
                           end
                       end
                   end
               end
               task.wait(0.5)
           end
       end)
   end,
})

-- [ หมวด Trade System - ระบบ Warp Behind + Input Box ] --

-- ช่องใส่ชื่อผู้เล่น (Type Name)
TradeTab:CreateInput({
   Name = "Type Player Name",
   PlaceholderText = "Enter full name...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
       SelectedPlayer = Text
       StatusLabel:Set("Status: Selected " .. Text)
   end,
})

-- ปุ่มวาร์ปไปส่ง (Warp Behind Mode)
TradeTab:CreateButton({
   Name = "Warp Behind & Send Gift",
   Callback = function()
       if SelectedPlayer == "" then
           StatusLabel:Set("Status: Error - No Name Entered")
           return
       end

       local lp = game.Players.LocalPlayer
       local targetPlayer = game:GetService("Players"):FindFirstChild(SelectedPlayer)
       
       if targetPlayer then
           local targetChar = targetPlayer.Character
           if targetChar and (targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Head")) then
               StatusLabel:Set("Status: Target Found! Warping...")
               
               -- 1. วาร์ปไปด้านหลังผู้เล่น
               warpBehind(targetChar)
               
               -- 2. รอให้ Server อัปเดตตำแหน่ง
               task.wait(0.2)
               
               -- 3. ส่ง Gift
               local args = { targetPlayer }
               game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("GiftEvent"):FireServer(unpack(args))
               
               StatusLabel:Set("Status: Gift Sent to " .. SelectedPlayer)
               Rayfield:Notify({Title = "Success", Content = "วาร์ปไปส่งของเรียบร้อย!", Duration = 2})
           else
               StatusLabel:Set("Status: Error - Character not loaded")
           end
       else
           StatusLabel:Set("Status: Error - Player not found in server")
       end
   end,
})

-- ปุ่มวาร์ปกลับที่เดิม (กรณีอยากวาร์ปกลับเอง)
TradeTab:CreateButton({
   Name = "Warp Back (Safe Point)",
   Callback = function()
       local zone = workspace.RarityParts:GetChildren()[18]
       if zone and game.Players.LocalPlayer.Character then
           game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = zone.CFrame + Vector3.new(0, 5, 0)
           StatusLabel:Set("Status: Returned to OG Zone")
       end
   end,
})

Rayfield:LoadConfiguration()
