local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Monhub | V1.2 (Instant Trade)",
   LoadingTitle = "Advanced Positioning System",
   LoadingSubtitle = "by Gemini Pro Writer",
   ConfigurationPath = "ProConfig"
})

local MainTab = Window:CreateTab("Auto Warp", 4483362458)
local TradeTab = Window:CreateTab("Trade System", 4483362458)

local SelectedPlayer = ""

-- [ ฟังก์ชันวาร์ปไปด้านหลังไอเทม - ห้ามแก้ตามสั่ง ] --
local function warpBehind(target)
    local lp = game.Players.LocalPlayer
    if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        local targetCFrame = target:IsA("Model") and target:GetPivot() or target.CFrame
        local backPos = targetCFrame * CFrame.new(0, 0, 3) 
        hrp.CFrame = backPos
    end
end

-- [ หมวด Auto Warp ] --
MainTab:CreateButton({
   Name = "Mythical Zone Goto",
   Callback = function()
       local rarityParts = workspace:FindFirstChild("RarityParts")
       if rarityParts then
           local target = rarityParts:GetChildren()[12]
           if target and game.Players.LocalPlayer.Character then
               local targetCFrame = target:IsA("Model") and target:GetPivot() or target.CFrame
               game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = targetCFrame + Vector3.new(0, 5, 0)
               Rayfield:Notify({Title = "Teleport Success", Content = "วาร์ปไป Mythical Zone แล้ว!", Duration = 2})
           end
       end
   end,
})

MainTab:CreateToggle({
   Name = "Auto Warp Behind & Grab",
   CurrentValue = false,
   Flag = "WarpGrab",
   Callback = function(Value)
       _G.WarpGrab = Value
       task.spawn(function()
           while _G.WarpGrab do
               local rarityParts = workspace:FindFirstChild("RarityParts")
               if rarityParts then
                   for _, idx in pairs({17, 18}) do
                       local zone = rarityParts:GetChildren()[idx]
                       local itemsFolder = zone and zone:FindFirstChild("Items")
                       if itemsFolder then
                           for _, item in pairs(itemsFolder:GetChildren()) do
                               if not _G.WarpGrab then break end
                               warpBehind(item)
                               task.wait(0.1)
                               local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                               if prompt then
                                   prompt.HoldDuration = 0
                                   fireproximityprompt(prompt)
                               end
                               game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("CollectEvent"):FireServer("CollectItem")
                               task.wait(0.1)
                           end
                       end
                   end
               end
               task.wait(0.5)
           end
       end)
   end,
})

-- [ หมวด Trade System - ปรับปรุงการหาตัวผู้เล่น ] --
local function getPlayers()
    local p = {}
    for _, player in pairs(game:GetService("Players"):GetPlayers()) do
        if player ~= game.Players.LocalPlayer then
            table.insert(p, player.Name)
        end
    end
    return p
end

local PlayerDropdown = TradeTab:CreateDropdown({
   Name = "Select Player to Gift",
   Options = getPlayers(),
   CurrentOption = "",
   Flag = "SelectedTarget",
   Callback = function(Option)
       SelectedPlayer = Option
   end,
})

TradeTab:CreateButton({
   Name = "Refresh Player List",
   Callback = function()
       PlayerDropdown:Refresh(getPlayers(), true)
   end,
})

TradeTab:CreateButton({
   Name = "Send Gift (Instant Snap)",
   Callback = function()
       if SelectedPlayer ~= "" then
           local lp = game.Players.LocalPlayer
           local targetPlayer = game:GetService("Players"):FindFirstChild(SelectedPlayer)
           
           -- ตรวจสอบตัวละครเป้าหมายแบบละเอียด
           local targetChar = targetPlayer and targetPlayer.Character
           local targetHrp = targetChar and (targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso") or targetChar:FindFirstChild("UpperTorso"))
           
           if targetHrp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
               local oldCFrame = lp.Character.HumanoidRootPart.CFrame
               
               -- วาร์ปไปจุดที่เขาอยู่
               lp.Character.HumanoidRootPart.CFrame = targetHrp.CFrame
               
               task.wait(0.15) -- เพิ่มเวลานิดหน่อยเพื่อให้ Server มั่นใจว่าเราอยู่ตรงนั้นจริง
               
               local args = { targetPlayer }
               game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("GiftEvent"):FireServer(unpack(args))
               
               task.wait(0.05)
               lp.Character.HumanoidRootPart.CFrame = oldCFrame
               
               Rayfield:Notify({Title = "Trade Success", Content = "ส่ง Gift ให้ " .. SelectedPlayer .. " แล้ว!", Duration = 2})
           else
               -- ถ้าหาไม่เจอ ให้ลองส่งแบบไม่วาร์ปดูเผื่อฟลุ๊ค
               game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("GiftEvent"):FireServer(unpack({targetPlayer}))
               Rayfield:Notify({Title = "Warning", Content = "หาตัวไม่เจอ แต่พยายามส่ง Remote ให้แล้ว", Duration = 2})
           end
       else
           Rayfield:Notify({Title = "Error", Content = "กรุณาเลือกผู้เล่นก่อน!", Duration = 2})
       end
   end,
})

Rayfield:LoadConfiguration()
