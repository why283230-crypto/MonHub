local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Monhub | V1.2.2 (Trade Master)",
   LoadingTitle = "Warp & Stealth Trade System",
   LoadingSubtitle = "by Gemini Pro Writer",
   ConfigurationPath = "ProConfig"
})

local MainTab = Window:CreateTab("Auto Warp", 4483362458)
local TradeTab = Window:CreateTab("Trade System", 4483362458)

-- [ Variables ] --
local SelectedPlayerObj = nil
local RS = game:GetService("ReplicatedStorage")
local LP = game:GetService("Players").LocalPlayer

-- [ ฟังก์ชันวาร์ปไปด้านหลังไอเทม - ห้ามแก้ตามสั่ง ] --
local function warpBehind(target)
    if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LP.Character.HumanoidRootPart
        local targetCFrame = target:IsA("Model") and target:GetPivot() or target.CFrame
        local backPos = targetCFrame * CFrame.new(0, 0, 3) 
        hrp.CFrame = backPos
    end
end

-- [ หมวด Auto Warp (12, 17, 18) ] --

MainTab:CreateButton({
   Name = "Mythical Zone Goto",
   Callback = function()
       local rarityParts = workspace:FindFirstChild("RarityParts")
       local target = rarityParts and rarityParts:GetChildren()[12]
       if target and LP.Character then
           local pos = target:IsA("Model") and target:GetPivot() or target.CFrame
           LP.Character.HumanoidRootPart.CFrame = pos + Vector3.new(0, 5, 0)
       end
   end,
})

MainTab:CreateToggle({
   Name = "Auto Warp Behind & Grab",
   CurrentValue = false,
   Flag = "WarpGrab",
   Callback = function(Value)
       _G.WarpGrab = Value
       task.spawn(function()
           while _G.WarpGrab do
               local rarityParts = workspace:FindFirstChild("RarityParts")
               if rarityParts then
                   for _, idx in pairs({17, 18}) do
                       local zone = rarityParts:GetChildren()[idx]
                       local itemsFolder = zone and zone:FindFirstChild("Items")
                       if itemsFolder then
                           for _, item in pairs(itemsFolder:GetChildren()) do
                               if not _G.WarpGrab then break end
                               warpBehind(item)
                               task.wait(0.1)
                               local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                               if prompt then
                                   prompt.HoldDuration = 0
                                   fireproximityprompt(prompt)
                               end
                               RS:WaitForChild("Events"):WaitForChild("CollectEvent"):FireServer("CollectItem")
                               task.wait(0.1)
                           end
                       end
                   end
               end
               task.wait(0.5)
           end
       end)
   end,
})

-- [ หมวด Trade System - ปรับปรุงตามสคริปต์ที่คุณให้ ] --

TradeTab:CreateSection("--- Connection Status ---")
local PlayerStatus = TradeTab:CreateLabel("Status: ⚪ Waiting for Input")
local IDStatus = TradeTab:CreateLabel("ID: ⚪ None")

TradeTab:CreateSection("--- Search Target ---")

TradeTab:CreateInput({
   Name = "Search Player Name",
   PlaceholderText = "พิมพ์ชื่อเพื่อล็อคเป้าหมาย...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      if Text == "" then return end
      for _, p in pairs(game:GetService("Players"):GetPlayers()) do
         -- ระบบค้นหาชื่อแบบบางส่วน (ไม่ต้องพิมพ์เต็มก็ได้)
         if p.Name:lower():sub(1, #Text) == Text:lower() then
            SelectedPlayerObj = p
            PlayerStatus:Set("Status: ✅ Locked! (" .. p.Name .. ")")
            IDStatus:Set("ID: " .. tostring(p.UserId))
            return
         end
      end
      SelectedPlayerObj = nil
      PlayerStatus:Set("Status: ❌ Not Found")
      IDStatus:Set("ID: ⚪ None")
   end,
})

TradeTab:CreateButton({
   Name = "🚀 Warp & Send Gift",
   Callback = function()
      if SelectedPlayerObj then
         local TargetChar = SelectedPlayerObj.Character
         if TargetChar and TargetChar:FindFirstChild("HumanoidRootPart") then
            
            -- 1. วาร์ปไปข้างหลังผู้เล่น (Offset 3 หน่วย)
            pcall(function()
               local BehindPos = TargetChar.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
               LP.Character.HumanoidRootPart.CFrame = BehindPos
            end)
            
            PlayerStatus:Set("Status: 🏃 Warping to Target...")
            task.wait(0.3) -- รอตำแหน่งอัปเดต
            
            -- 2. ส่ง Remote GiftEvent (ใช้ตัวที่คุณให้มา)
            pcall(function()
               local args = { SelectedPlayerObj }
               RS:WaitForChild("Events"):WaitForChild("GiftEvent"):FireServer(unpack(args))
            end)
            
            PlayerStatus:Set("Status: ✅ Gift Sent to " .. SelectedPlayerObj.Name)
            Rayfield:Notify({Title = "Success", Content = "Warped & Gift Sent!", Duration = 2})
         else
            PlayerStatus:Set("Status: ❌ Target too far or Dead")
            Rayfield:Notify({Title = "Error", Content = "Could not find player body", Duration = 3})
         end
      else
         Rayfield:Notify({Title = "Warning", Content = "Please search and lock a player first!", Duration = 3})
      end
   end,
})

-- ปุ่มวาร์ปกลับจุดปลอดภัย (OG Zone)
TradeTab:CreateButton({
   Name = "🏠 Return to OG Zone",
   Callback = function()
       local zone = workspace.RarityParts:GetChildren()[18]
       if zone and LP.Character then
           LP.Character.HumanoidRootPart.CFrame = zone.CFrame + Vector3.new(0, 5, 0)
           PlayerStatus:Set("Status: 🏠 Returned to Base")
       end
   end,
})

Rayfield:LoadConfiguration()
