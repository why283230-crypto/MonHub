-- 2. BUY TAB (ระบบซื้อ)
-- ==========================================
local T2 = Window:CreateTab("Auto Buy", 4483362458)
T2:CreateToggle({Name = "Buy ALL (33 Blocks)", Flag = "f_ba", Callback = function(V) _G.BA = V while _G.BA do for _, n in pairs(WaterfallList) do if not _G.BA then break end pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999) end) end task.wait(0.1) end end})
T2:CreateDropdown({Name = "Multi-Buy Select", Options = NormalList, MultipleOptions = true, Flag = "f_mb", Callback = function(O) Vars.SelectedBuyList = O end})
T2:CreateToggle({Name = "Buy Selected Max", Flag = "f_bs", Callback = function(V) _G.BS = V while _G.BS do for _, n in pairs(Vars.SelectedBuyList) do if not _G.BS then break end pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999) end) end task.wait(0.1) end end})

