-- [[ Tab 1: Roll Systems ]]
-- ==========================================
local RollTab = Window:CreateTab("Roll Systems", 4483362458)

RollTab:CreateSection("Smart Waterfall (Auto Best)")
RollTab:CreateToggle({
   Name = "Enable Smart Waterfall",
   Info = "Scan UI and auto roll best block available",
   CurrentValue = false,
   Flag = "SmartWaterfall_T", -- ใช้ Flag เพื่อบันทึกค่า
   Callback = function(Value)
      _G.SmartRollActive = Value
      StatusFrame.Visible = Value
      if not Value then 
         pcall(function() game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(false) end)
         return 
      end
      task.spawn(function()
         while _G.SmartRollActive do
            local player = game:GetService("Players").LocalPlayer
            local inv = player.PlayerGui:FindFirstChild("Main") and player.PlayerGui.Main:FindFirstChild("DiceContainer") and player.PlayerGui.Main.DiceContainer:FindFirstChild("Inventory") and player.PlayerGui.Main.DiceContainer.Inventory:FindFirstChild("Scroll")
            local bestFound = "None"
            for _, blockName in ipairs(WaterfallList) do
               if not _G.SmartRollActive then break end
               local isAvailable = false
               if inv then
                  local uiItem = inv:FindFirstChild(blockName)
                  if uiItem and uiItem.Visible == true then
                     local lockOverlay = uiItem:FindFirstChild("Locked")
                     if not lockOverlay or lockOverlay.Visible == false then isAvailable = true end
                  end
               end
               if isAvailable then
                  bestFound = blockName
                  pcall(function()
                     game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(blockName)
                     game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true)
                  end)
                  break
               end
            end
            MainStatus.Text = "🚀 Locked: " .. bestFound
            ScanStatus.Text = "Turbo Sync: " .. os.date("%X")
            task.wait(0.01)
         end
      end)
   end,
})

RollTab:CreateSection("Manual Roll")
RollTab:CreateDropdown({
   Name = "Select Block",
   Options = NormalList,
   Flag = "ManualBlock_D",
   Callback = function(Option) Config.ManualTarget = Option[1] end,
})
RollTab:CreateToggle({
   Name = "Start Manual Roll",
   CurrentValue = false,
   Flag = "ManualRoll_T",
   Callback = function(Value)
      _G.ManualRoll = Value
      while _G.ManualRoll do
         if Config.ManualTarget ~= "" then
            pcall(function() 
               game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(Config.ManualTarget)
               game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true)
            end)
         end
         task.wait(0.1)
      end
   end,
})

