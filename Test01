-- [[ DATA LISTS ]]
local WaterfallList = {"PinnacleBlock", "VerdictBlock", "HellcoreBlock", "DoomBlock", "BloodcodeBlock", "VortexBlock", "VercaBlock", "AnomalyBlock", "PhantomBlock", "CelestialEmperorBlock", "RadiantBlock", "AetherialBlock", "TheEndBlock", "KingsMantleBlock", "ToxicReactorBlock", "MoltenCoreBlock", "OuroborosBlock", "KingSunBlock", "InfinityBlock", "TimeBenderBlock", "BrambleBlock", "MagicBlock", "HeavenlyBlock", "DevilBlock", "AscendantBlock", "QuantumBlock", "GalaxyBlock", "MythicBlock", "LegendaryBlock", "EpicBlock", "RareBlock", "UncommonBlock", "CommonBlock"}
local NormalList = {"CommonBlock", "UncommonBlock", "RareBlock", "EpicBlock", "LegendaryBlock", "MythicBlock", "GalaxyBlock", "QuantumBlock", "AscendantBlock", "DevilBlock", "HeavenlyBlock", "MagicBlock", "BrambleBlock", "TimeBenderBlock", "InfinityBlock", "KingSunBlock", "OuroborosBlock", "MoltenCoreBlock", "ToxicReactorBlock", "KingsMantleBlock", "TheEndBlock", "AetherialBlock", "RadiantBlock", "CelestialEmperorBlock", "PhantomBlock", "AnomalyBlock", "VercaBlock", "VortexBlock", "BloodcodeBlock", "DoomBlock", "HellcoreBlock", "VerdictBlock", "PinnacleBlock"}
local PetEggs = {"Basic", "Coconut", "Crocodile", "Yeti", "Cupcake", "GoldenBasic"}

local Vars = { ManualTarget = "", SelectedBuyList = {}, SelectedEgg = "", SelectedPlot = "1" }

-- ==========================================
-- 1. ROLL TAB (ระบบสุ่ม)
-- ==========================================
local T1 = Window:CreateTab("Roll Systems", 4483362458)
T1:CreateSection("Smart Waterfall (Auto Best)")
T1:CreateToggle({
   Name = "Enable Smart Waterfall",
   CurrentValue = false,
   Flag = "f_wf",
   Callback = function(Value)
      _G.WF_Active = Value
      if not Value then pcall(function() game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(false) end) return end
      task.spawn(function()
         while _G.WF_Active do
            local inv = game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("Main") and game:GetService("Players").LocalPlayer.PlayerGui.Main:FindFirstChild("DiceContainer") and game:GetService("Players").LocalPlayer.PlayerGui.Main.DiceContainer:FindFirstChild("Inventory") and game:GetService("Players").LocalPlayer.PlayerGui.Main.DiceContainer.Inventory:FindFirstChild("Scroll")
            for _, b in ipairs(WaterfallList) do
               if not _G.WF_Active then break end
               local uiItem = inv and inv:FindFirstChild(b)
               if uiItem and uiItem.Visible == true then
                  local lock = uiItem:FindFirstChild("Locked")
                  if not lock or lock.Visible == false then
                     pcall(function() 
                        game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(b) 
                        game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true) 
                     end)
                     break
                  end
               end
            end
            task.wait(0.01)
         end
      end)
   end,
})
T1:CreateSection("Manual Roll")
T1:CreateDropdown({Name = "Select Block", Options = NormalList, Flag = "f_mr_d", Callback = function(O) Vars.ManualTarget = O[1] end})
T1:CreateToggle({Name = "Start Manual Roll", Flag = "f_mr_t", Callback = function(V) _G.MR_Active = V while _G.MR_Active do if Vars.ManualTarget ~= "" then pcall(function() game:GetService("ReplicatedStorage").Network.Client.RollBlock:InvokeServer(Vars.ManualTarget) game:GetService("ReplicatedStorage").Network.Client.ToggleAutoRoll:FireServer(true) end) end task.wait(0.1) end end})

