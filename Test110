-- [[ Webhook Function ]]
local function SendSummaryWebhook(items, refreshTime)
    if Config.WebhookURL == "" or Config.WebhookURL == nil then return end
    
    local list = ""
    if type(items) == "table" then
        for _, name in pairs(items) do list = list .. "✅ " .. name .. "\n" end
    else
        list = items
    end

    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then return end

    pcall(function()
        requestFunc({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["embeds"] = {{
                    ["title"] = "🛍️ MonHub | สรุปยอดซื้อสำเร็จ",
                    ["description"] = "รอบรีร้านค้าเวลา: **" .. refreshTime .. "**\n\n**รายการที่ได้จริง:**\n" .. list,
                    ["color"] = 0x00ffff,
                    ["footer"] = {["text"] = "MonHub Precision Log | " .. os.date("%X")}
                }}
            })
        })
    end)
end

