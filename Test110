-- [[ Tab 2: Auto Buy (PRECISION SYNC) ]]
-- ==========================================
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)

BuyTab:CreateSection("ระบบซื้อและสรุปยอด (Reset ทุก 5 นาที)")
BuyTab:CreateToggle({
   Name = "Auto Buy All + Precision Log",
   Flag = "BuyAll_Toggle",
   Callback = function(V) 
      _G.BAll = V 
      while _G.BAll do 
         local minute = nil
         local fullTime = "00:00"
         
         -- [[ Hard Sync Time Detection ]]
         for _, v in pairs(game.Players.LocalPlayer.PlayerGui:GetDescendants()) do
             if v:IsA("TextLabel") and v.Visible and v.Text:find(":") then
                 local m = v.Text:match("(%d+):")
                 if m then minute = tonumber(m); fullTime = v.Text; break end
             end
         end

         -- ตรวจสอบรอบนาที (0, 5, 10, ...)
         if minute and (minute % 5 == 0) then
            local successList = {}
            local conn = game.Players.LocalPlayer.Backpack.ChildAdded:Connect(function(c) 
                table.insert(successList, c.Name) 
            end)

            Rayfield:Notify({Title = "Shop Refreshing!", Content = "เริ่มกวาดของรอบนาทีที่ "..minute, Duration = 3})

            -- ซื้อซ้ำๆ ในนาทีนั้น
            repeat
               task.wait(1)
               for _, n in pairs(WaterfallList) do 
                  pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999) end) 
               end
               
               -- อัปเดตนาทีเพื่อเช็คว่าเปลี่ยนหรือยัง
               local checkMin = nil
               for _, v in pairs(game.Players.LocalPlayer.PlayerGui:GetDescendants()) do
                   if v:IsA("TextLabel") and v.Visible and v.Text:find(":") then
                       local m = v.Text:match("(%d+):")
                       if m then checkMin = tonumber(m) break end
                   end
               end
            until (checkMin ~= minute) or not _G.BAll

            conn:Disconnect()

            -- ส่ง Log เฉพาะเมื่อได้ของจริง
            if #successList > 0 then
                local uniqueItems = {}
                local hash = {}
                for _, v in ipairs(successList) do
                   if not hash[v] then table.insert(uniqueItems, v); hash[v] = true end
                end
                SendSummaryWebhook(uniqueItems, fullTime)
            end
            task.wait(10) 
         end
         task.wait(1.5) 
      end 
   end,
})

