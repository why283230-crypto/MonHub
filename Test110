-- [[ Tab 1: Roll Systems ]]
-- ==========================================
local RollTab = Window:CreateTab("Roll Systems", 4483362458)
RollTab:CreateSection("Smart Waterfall (ระบบลดระดับอัตโนมัติ)")
RollTab:CreateToggle({
   Name = "Enable Smart Waterfall (Auto Best)",
   CurrentValue = false,
   Flag = "SmartRoll_Toggle",
   Callback = function(Value)
      _G.SmartRollActive = Value
      if not Value then pcall(function() RS.Network.Client.ToggleAutoRoll:FireServer(false) end) return end
      task.spawn(function()
         while _G.SmartRollActive do
            local inv = LP.PlayerGui:FindFirstChild("Main") and LP.PlayerGui.Main:FindFirstChild("DiceContainer") and LP.PlayerGui.Main.DiceContainer:FindFirstChild("Inventory") and LP.PlayerGui.Main.DiceContainer.Inventory:FindFirstChild("Scroll")
            for _, blockName in ipairs(WaterfallList) do
               if not _G.SmartRollActive then break end
               local isAvailable = false
               if inv then
                  local uiItem = inv:FindFirstChild(blockName)
                  if uiItem and uiItem.Visible == true then
                     local lockOverlay = uiItem:FindFirstChild("Locked")
                     if not lockOverlay or lockOverlay.Visible == false then isAvailable = true end
                  end
               end
               if isAvailable then
                  pcall(function() RS.Network.Client.RollBlock:InvokeServer(blockName) RS.Network.Client.ToggleAutoRoll:FireServer(true) end)
                  break
               end
            end
            task.wait(0.01)
         end
      end)
   end,
})

