-- [[ Global States & Webhook Logic ]]
local Config = { ManualTarget = "", SelectedEgg = "", SelectedPlot = "1", WebhookURL = "" }
local purchaseQueue = {}
local isWaiting = false
local waitTime = 2 
local RarityOrder = {}
for i, name in ipairs(WaterfallList) do RarityOrder[name] = i end

local function formatNumber(n)
    n = tonumber(n) or 0
    if n >= 1000000 then return string.format("%.1fm", n/1000000):gsub("%.0m", "m")
    elseif n >= 1000 then return string.format("%.1fk", n/1000):gsub("%.0k", "k")
    else return tostring(n) end
end

local function sendSummaryLog()
    if Config.WebhookURL == "" or Config.WebhookURL == nil then purchaseQueue = {}; isWaiting = false return end
    local sortedList = {}
    for name, data in pairs(purchaseQueue) do table.insert(sortedList, {Name = name, Bought = data.bought, Total = data.total}) end
    table.sort(sortedList, function(a, b) return (RarityOrder[a.Name] or 0) > (RarityOrder[b.Name] or 0) end)
    local report = ""
    for _, item in ipairs(sortedList) do report = report .. "🛒 **" .. item.Name .. "**: +" .. item.Bought .. " (รวม: `" .. formatNumber(item.Total) .. "`)\n" end
    local payload = HttpService:JSONEncode({
        ["embeds"] = {{
            ["title"] = "🛍️ MonHub | รายงานการซื้อสรุปยอด",
            ["description"] = report,
            ["color"] = 0x32cd32,
            ["footer"] = {["text"] = "Player: " .. player.Name},
            ["timestamp"] = DateTime.now():ToIsoDate()
        }}
    })
    local request = (syn and syn.request) or (http and http.request) or http_request or (Fluxus and Fluxus.request)
    if request then request({Url = Config.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload}) end
    purchaseQueue = {}; isWaiting = false
end

-- [[ Auto Monitor System ]]
task.spawn(function()
    while true do
        for _, v in ipairs(player:GetDescendants()) do
            if v:IsA("ValueBase") then
                local isBlock = false
                for _, bn in pairs(WaterfallList) do if v.Name == bn then isBlock = true break end end
                if isBlock and not v:GetAttribute("MonMonitored") then
                    v:SetAttribute("MonMonitored", true)
                    local lastVal = v.Value
                    v.Changed:Connect(function(newVal)
                        if newVal > lastVal then
                            local diff = newVal - lastVal
                            if purchaseQueue[v.Name] then purchaseQueue[v.Name].bought = purchaseQueue[v.Name].bought + diff; purchaseQueue[v.Name].total = newVal
                            else purchaseQueue[v.Name] = {bought = diff, total = newVal} end
                            if not isWaiting then isWaiting = true; task.delay(waitTime, sendSummaryLog) end
                        end
                        lastVal = newVal
                    end)
                end
            end
        end
        task.wait(5)
    end
end)

