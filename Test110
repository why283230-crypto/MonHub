local InvTab = Window:CreateTab("Inventory Info", 4483362458)
local PriceDatabase = {}
local InvLabels = {}

-- [[ ฟังก์ชันสแกนหาราคา ]]
local function BuildPriceMap()
    local plots = workspace:FindFirstChild("Plots")
    if plots then
        for _, plot in pairs(plots:GetChildren()) do
            local slots = plot:FindFirstChild("Slots")
            if slots then
                for _, slot in pairs(slots:GetChildren()) do
                    for _, model in pairs(slot:GetChildren()) do
                        if model:IsA("Model") and model:FindFirstChild("Head") then
                            local tag = model.Head:FindFirstChild("PodiumTag")
                            if tag and tag.Frame:FindFirstChild("CashPerSecond") then
                                local entName = model:GetAttribute("EntityName") or model.Name
                                PriceDatabase[entName] = tag.Frame.CashPerSecond.Text
                            end
                        end
                    end
                end
            end
        end
    end
end

-- [[ ฟังก์ชันส่ง Webhook ]]
local function SendToDiscord()
    if Config.WebhookURL == "" or not Config.WebhookURL:find("discord.com") then
        Rayfield:Notify({Title = "Webhook Error", Content = "กรุณาใส่ Discord URL ให้ถูกต้อง!", Duration = 3})
        return
    end
    
    local items = LP.Backpack:GetChildren()
    local itemList = ""
    for i, item in ipairs(items) do
        if i > 20 then break end
        local entName = item:GetAttribute("EntityName") or item.Name
        local price = PriceDatabase[entName] or "No Data"
        itemList = itemList .. string.format("📦 **%s** | 💰 Income: `%s`\n", entName, price)
    end

    local Data = {
        ["embeds"] = {{
            ["title"] = "📊 MonHub | Inventory Report",
            ["description"] = "User: **" .. LP.Name .. "**",
            ["color"] = tonumber(0x5865F2),
            ["fields"] = { {["name"] = "Items in Backpack", ["value"] = itemList ~= "" and itemList or "None", ["inline"] = false} },
            ["footer"] = { ["text"] = "Suriya Janthra Tech | " .. os.date("%X") }
        }}
    }

    pcall(function()
        local jsonData = game:GetService("HttpService"):JSONEncode(Data)
        request({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
    end)
end

