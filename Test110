local TradeTab = Window:CreateTab("Trade & Warp", 4483362458)
TradeTab:CreateSection("--- Connection Status ---")
local PlayerStatus = TradeTab:CreateLabel("Status: ⚪ Waiting")
local IDStatus = TradeTab:CreateLabel("ID: ⚪ None")

TradeTab:CreateInput({
   Name = "Search Player Name",
   PlaceholderText = "Type target name...",
   Callback = function(Text)
      for _, p in pairs(Players:GetPlayers()) do
         if p.Name:lower():sub(1, #Text) == Text:lower() then
            SelectedPlayerID = p.UserId; SelectedPlayerObj = p
            PlayerStatus:Set("Status: ✅ Locked! (" .. p.Name .. ")")
            IDStatus:Set("ID: " .. tostring(SelectedPlayerID))
            return
         end
      end
   end,
})

TradeTab:CreateButton({
   Name = "🚀 Warp & Send Trade",
   Callback = function()
      if SelectedPlayerID and SelectedPlayerObj then
         pcall(function()
            LP.Character.HumanoidRootPart.CFrame = SelectedPlayerObj.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
            task.wait(0.3)
            TradeRemote:FireServer("request", tonumber(SelectedPlayerID))
         end)
         Rayfield:Notify({Title = "Trade", Content = "Warped and Requested!", Duration = 2})
      end
   end,
})

-- ==========================================
-- [[ TAB 6: Inventory (Fix: Backpack Search) ]]
-- ==========================================
local InvTab = Window:CreateTab("Inventory", 4483362458)
InvTab:CreateSection("--- Backpack Units ---")

local InvLabels = {} -- เก็บ Label ไว้เพื่ออัปเดต

local function RefreshInv()
    -- ล้างข้อความใน Label เก่าก่อนดึงใหม่
    for _, v in pairs(InvLabels) do v:Set("") end
    
    local Backpack = LP:FindFirstChild("Backpack")
    if Backpack then
        local items = Backpack:GetChildren()
        for i, item in ipairs(items) do
            if i > 25 then break end -- จำกัดไว้ 25 แถวกัน UI รกครับ
            
            -- พยายามดึงราคาจาก Value ภายในตัว Unit
            local price = "N/A"
            if item:FindFirstChild("Value") then
                price = tostring(item.Value.Value)
            elseif item:FindFirstChild("Price") then
                price = tostring(item.Price.Value)
            end
            
            local displayText = "📦 [" .. i .. "] " .. item.Name .. " | 💰 " .. price
            
            if InvLabels[i] then
                InvLabels[i]:Set(displayText)
            else
                InvLabels[i] = InvTab:CreateLabel(displayText)
            end
        end
        Rayfield:Notify({Title = "Inventory", Content = "Found " .. #items .. " units in Backpack", Duration = 2})
    end
end

InvTab:CreateButton({
   Name = "🔄 Refresh Inventory",
   Callback = function()
      RefreshInv()
   end,
})

