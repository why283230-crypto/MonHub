-- ==========================================
local TradeTab = Window:CreateTab("Trade & Warp", 4483362458)

local SelectedPlayerID = nil
local SelectedPlayerObj = nil
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local TradeRemote = game:GetService("ReplicatedStorage"):WaitForChild("Network"):WaitForChild("Client"):WaitForChild("Trade")

TradeTab:CreateSection("--- Connection Status ---")
local PlayerStatus = TradeTab:CreateLabel("Status: ⚪ Waiting for Input")
local IDStatus = TradeTab:CreateLabel("ID: ⚪ None")

TradeTab:CreateSection("--- Search Target ---")
TradeTab:CreateInput({
   Name = "Search Player Name",
   PlaceholderText = "พิมพ์ชื่อเพื่อล็อคเป้าหมาย...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      for _, p in pairs(Players:GetPlayers()) do
         if p.Name:lower():sub(1, #Text) == Text:lower() then
            SelectedPlayerID = p.UserId
            SelectedPlayerObj = p
            PlayerStatus:Set("Status: ✅ Locked! (" .. p.Name .. ")")
            IDStatus:Set("ID: " .. tostring(SelectedPlayerID))
            return
         end
      end
      SelectedPlayerID = nil; SelectedPlayerObj = nil
      PlayerStatus:Set("Status: ❌ Not Found"); IDStatus:Set("ID: ⚪ None")
   end,
})

TradeTab:CreateButton({
   Name = "📍 Target Nearest Player",
   Callback = function()
      local closest = nil
      local dist = math.huge
      for _, p in pairs(Players:GetPlayers()) do
         if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; closest = p end
         end
      end
      if closest then
         SelectedPlayerID = closest.UserId; SelectedPlayerObj = closest
         PlayerStatus:Set("Status: ✅ Locked Nearest!"); IDStatus:Set("ID: " .. tostring(SelectedPlayerID))
         Rayfield:Notify({Title = "Targeted", Content = "Locked on: " .. closest.Name, Duration = 2})
      end
   end,
})

TradeTab:CreateSection("--- Actions ---")
TradeTab:CreateButton({
   Name = "🚀 Warp & Send Trade",
   Callback = function()
      if SelectedPlayerID and SelectedPlayerObj then
         local TargetChar = SelectedPlayerObj.Character
         if TargetChar and TargetChar:FindFirstChild("HumanoidRootPart") then
            pcall(function()
               local BehindPos = TargetChar.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
               LP.Character.HumanoidRootPart.CFrame = BehindPos
            end)
            Rayfield:Notify({Title = "Warping", Content = "Moving to " .. SelectedPlayerObj.Name, Duration = 1})
            task.wait(0.3)
            pcall(function()
               TradeRemote:FireServer("request", tonumber(SelectedPlayerID))
            end)
            Rayfield:Notify({Title = "Success", Content = "Request Sent!", Duration = 2})
         else
            Rayfield:Notify({Title = "Error", Content = "Target character missing!", Duration = 3})
         end
      else
         Rayfield:Notify({Title = "Warning", Content = "Please select a target first!", Duration = 3})
      end
   end,
})

