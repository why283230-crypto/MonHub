-- [[ DATA LISTS - คงเดิม ]]
local WaterfallList = { "PinnacleBlock", "VerdictBlock", "HellcoreBlock", "DoomBlock", "BloodcodeBlock", "VortexBlock", "VercaBlock", "AnomalyBlock", "PhantomBlock", "CelestialEmperorBlock", "RadiantBlock", "AetherialBlock", "TheEndBlock", "KingsMantleBlock", "ToxicReactorBlock", "MoltenCoreBlock", "OuroborosBlock", "KingSunBlock", "InfinityBlock", "TimeBenderBlock", "BrambleBlock", "MagicBlock", "HeavenlyBlock", "DevilBlock", "AscendantBlock", "QuantumBlock", "GalaxyBlock", "MythicBlock", "LegendaryBlock", "EpicBlock", "RareBlock", "UncommonBlock", "CommonBlock" }
local Config = { WebhookURL = "" }

-- [[ Webhook Function - ตัวที่พี่กด Test แล้วผ่าน ]]
local function SendSummaryWebhook(items, refreshTime)
    if Config.WebhookURL == "" or Config.WebhookURL == nil then return end
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then return end

    pcall(function()
        requestFunc({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["embeds"] = {{
                    ["title"] = "🛍️ MonHub | สรุปยอดซื้อสำเร็จ",
                    ["description"] = "รอบรีร้านค้า (เวลาจริง): **" .. refreshTime .. "**\n\n✅ ระบบสั่งกวาดซื้อเรียบร้อยแล้ว!",
                    ["color"] = 0x00ffff,
                    ["footer"] = {["text"] = "Sync by OS Time | " .. os.date("%X")}
                }}
            })
        })
    end)
end

-- ==========================================
-- [[ Tab 2: Auto Buy (THE ULTIMATE FIX) ]]
-- ==========================================
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)
BuyTab:CreateSection("ระบบกวาดร้านค้า (ใช้เวลาจริง)")

BuyTab:CreateToggle({
   Name = "Auto Buy + Force Log (Real Time)",
   Flag = "BuyAll_Toggle",
   Callback = function(V) 
      _G.BAll = V 
      while _G.BAll do 
         -- [[ ดึงนาทีจากเวลาจริงในเครื่องพี่เลย ไม่สน UI เกมแล้ว ]]
         local realMinute = tonumber(os.date("%M"))
         local realTimeStr = os.date("%X")

         -- ถ้าเครื่องพี่นาทีลงท้ายด้วย 0 หรือ 5 (เช่น 21:00, 21:05)
         if realMinute and (realMinute % 5 == 0) then
            Rayfield:Notify({Title = "Real Time Reset!", Content = "เริ่มกวาดของรอบนาทีที่ " .. realMinute, Duration = 3})

            -- กวาดของวนไปจนกว่าจะหมดนาทีนี้
            repeat
               if not _G.BAll then break end
               for _, n in pairs(WaterfallList) do 
                  pcall(function() 
                      game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999) 
                  end) 
               end
               task.wait(1.5)
               checkMin = tonumber(os.date("%M")) -- เช็คเวลาจริงเรื่อยๆ
            until (checkMin ~= realMinute) or not _G.BAll

            -- ส่ง Log ทันทีที่เข้านาทีที่ 1 หรือ 6
            SendSummaryWebhook("สคริปต์ทำการสั่งซื้อ Blocks ทั้งหมดในร้านค้าเรียบร้อย!", realTimeStr)
            
            task.wait(10) -- พักกัน Loop รันซ้ำ
         end
         task.wait(1) -- สแกนเวลาทุก 1 วินาที (ไม่กินสเปค)
      end 
   end,
})

