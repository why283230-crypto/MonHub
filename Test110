-- [[ DATA LISTS & SORTING ]]
local WaterfallList = { "PinnacleBlock", "VerdictBlock", "HellcoreBlock", "DoomBlock", "BloodcodeBlock", "VortexBlock", "VercaBlock", "AnomalyBlock", "PhantomBlock", "CelestialEmperorBlock", "RadiantBlock", "AetherialBlock", "TheEndBlock", "KingsMantleBlock", "ToxicReactorBlock", "MoltenCoreBlock", "OuroborosBlock", "KingSunBlock", "InfinityBlock", "TimeBenderBlock", "BrambleBlock", "MagicBlock", "HeavenlyBlock", "DevilBlock", "AscendantBlock", "QuantumBlock", "GalaxyBlock", "MythicBlock", "LegendaryBlock", "EpicBlock", "RareBlock", "UncommonBlock", "CommonBlock" }

local RarityOrder = {}
for i, name in ipairs(WaterfallList) do
    RarityOrder[name] = i 
end

local Config = { WebhookURL = "" }
local purchaseQueue = {}
local isWaiting = false
local waitTime = 2 

-- [[ ฟังก์ชันย่อตัวเลข ]]
local function formatNumber(n)
    n = tonumber(n) or 0
    if n >= 1000000 then return string.format("%.1fm", n/1000000):gsub("%.0m", "m")
    elseif n >= 1000 then return string.format("%.1fk", n/1000):gsub("%.0k", "k")
    else return tostring(n) end
end

-- [[ ฟังก์ชันส่ง Log แบบเรียงลำดับ ]]
local function SendSummaryLog()
    if Config.WebhookURL == "" or Config.WebhookURL == nil then 
        purchaseQueue = {}
        isWaiting = false
        return 
    end
    
    local sortedList = {}
    for name, data in pairs(purchaseQueue) do
        table.insert(sortedList, {Name = name, Bought = data.bought, Total = data.total})
    end

    -- เรียงจาก Common (เลขเยอะใน List) ไป Pinnacle (เลขน้อยใน List)
    table.sort(sortedList, function(a, b)
        return (RarityOrder[a.Name] or 0) > (RarityOrder[b.Name] or 0)
    end)

    local report = ""
    local hasData = false
    for _, item in ipairs(sortedList) do
        report = report .. "🛒 **" .. item.Name .. "**: +" .. item.Bought .. " (รวม: `" .. formatNumber(item.Total) .. "`)\n"
        hasData = true
    end

    if not hasData then return end

    local payload = game:GetService("HttpService"):JSONEncode({
        ["embeds"] = {{
            ["title"] = "🛍️ MonHub | รายงานการกวาดซื้อ (เรียงตามความหายาก)",
            ["description"] = report,
            ["color"] = 0x32cd32,
            ["footer"] = {["text"] = "Player: " .. game.Players.LocalPlayer.Name .. " | " .. os.date("%X")},
            ["timestamp"] = DateTime.now():ToIsoDate()
        }}
    })
    
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if request then
        request({Url = Config.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload})
    end

    purchaseQueue = {}
    isWaiting = false
end

-- [[ ระบบ Monitor ดักจับค่า Value ]]
task.spawn(function()
    while true do
        for _, v in ipairs(game.Players.LocalPlayer:GetDescendants()) do
            if v:IsA("ValueBase") then
                local isTarget = false
                for _, name in pairs(WaterfallList) do
                    if v.Name == name then isTarget = true break end
                end

                if isTarget and not v:GetAttribute("MonMonitored") then
                    v:SetAttribute("MonMonitored", true)
                    local lastValue = v.Value
                    v.Changed:Connect(function(newValue)
                        if tonumber(newValue) and newValue > lastValue then
                            local diff = newValue - lastValue
                            if purchaseQueue[v.Name] then
                                purchaseQueue[v.Name].bought = purchaseQueue[v.Name].bought + diff
                                purchaseQueue[v.Name].total = newValue
                            else
                                purchaseQueue[v.Name] = {bought = diff, total = newValue}
                            end
                            if not isWaiting then
                                isWaiting = true
                                task.delay(waitTime, SendSummaryLog)
                            end
                        end
                        lastValue = newValue
                    end)
                end
            end
        end
        task.wait(10)
    end
end)

