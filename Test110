-- [[ ฟังก์ชันส่ง Log การซื้อ ]]
local function SendBuyLog(blockName)
    if Config.WebhookURL == "" or not Config.WebhookURL:find("discord.com") then return end
    pcall(function()
        local data = {
            ["embeds"] = {{
                ["title"] = "🛒 Buy Log Success!",
                ["description"] = "User: **" .. game.Players.LocalPlayer.Name .. "**\nซื้อลูกเต๋า: **" .. blockName .. "**",
                ["color"] = 0x5865F2,
                ["footer"] = {["text"] = "MonHub V10.1 | " .. os.date("%X")}
            }}
        }
        request({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode(data)
        })
    end)
end

