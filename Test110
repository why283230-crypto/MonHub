-- [[ Tab 2: Auto Buy (ปรับปรุงให้สรุป Log) ]]
-- ==========================================
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)
BuyTab:CreateSection("ระบบซื้อทั้งหมด")
BuyTab:CreateToggle({
   Name = "Auto Buy ALL (Smart Timer)",
   Flag = "BuyAll_Toggle",
   Callback = function(V) 
      _G.BAll = V 
      while _G.BAll do 
         local playerGui = game.Players.LocalPlayer:FindFirstChild("PlayerGui")
         local foundTime = nil
         
         -- ดักเวลา 5 หรือ 4 นาที
         if playerGui then
            for _, v in pairs(playerGui:GetDescendants()) do
                if v:IsA("TextLabel") and v.Visible and v.Text:match("%d+:%d+") then
                    local t = v.Text
                    if t:find("^0?5:") or t:find("^0?4:") then foundTime = t break end
                end
            end
         end

         if foundTime then
            local successList = {}
            local backpack = game.Players.LocalPlayer:WaitForChild("Backpack")
            
            -- ดักจับว่ามีอะไรเพิ่มเข้ากระเป๋าจริงบ้าง
            local conn = backpack.ChildAdded:Connect(function(c) table.insert(successList, c.Name) end)

            for _, n in pairs(WaterfallList) do 
               if not _G.BAll then break end 
               pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999) end) 
            end 
            
            task.wait(2) -- รอของเข้า
            conn:Disconnect()
            
            -- ส่งสรุปทีเดียว
            if #successList > 0 then SendSummaryWebhook(successList, foundTime) end
            task.wait(60) 
         end
         task.wait(1) 
      end 
   end,
})

