-- [[ Tab 5: Trade & Warp ]]
-- ==========================================
local TradeTab = Window:CreateTab("Trade & Warp", 4483362458)
TradeTab:CreateSection("--- Connection Status ---")
local PlayerStatus = TradeTab:CreateLabel("Status: ⚪ Waiting")
local IDStatus = TradeTab:CreateLabel("ID: ⚪ None")

TradeTab:CreateInput({
   Name = "Search Player Name",
   PlaceholderText = "Target Name...",
   Callback = function(Text)
      for _, p in pairs(Players:GetPlayers()) do
         if p.Name:lower():sub(1, #Text) == Text:lower() then
            SelectedPlayerID = p.UserId; SelectedPlayerObj = p
            PlayerStatus:Set("Status: ✅ Locked! (" .. p.Name .. ")")
            IDStatus:Set("ID: " .. tostring(SelectedPlayerID))
            return
         end
      end
   end,
})

TradeTab:CreateButton({
   Name = "🚀 Warp & Send Trade",
   Callback = function()
      if SelectedPlayerID and SelectedPlayerObj then
         pcall(function()
            LP.Character.HumanoidRootPart.CFrame = SelectedPlayerObj.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
            task.wait(0.3)
            RS.Network.Client.Trade:FireServer("request", tonumber(SelectedPlayerID))
         end)
      end
   end,
})

-- ==========================================
-- [[ Tab 6: Inventory (New!) ]]
-- ==========================================
local InvTab = Window:CreateTab("Inventory", 4483362458)
InvTab:CreateSection("--- My Brainrots Items ---")

local InvContainer = {} -- เก็บ Label ไว้ลบเวลา Refresh

local function LoadInventory()
   -- ล้างหน้าจอเก่า (ถ้ามี)
   for _, label in pairs(InvContainer) do label:Set("--- Cleaned ---") end
   
   local Brainrots = LP:FindFirstChild("Brainrots")
   if Brainrots then
      local count = 0
      for _, item in pairs(Brainrots:GetChildren()) do
         count = count + 1
         -- ดึงชื่อและราคา (สมมติว่าราคาอยู่ใน Value หรือหาจากชื่อ)
         local itemName = item.Name
         local itemValue = item:FindFirstChild("Value") and item.Value.Value or "???"
         
         local entry = InvTab:CreateLabel("📦 " .. itemName .. " | Price: 💰 " .. tostring(itemValue))
         table.insert(InvContainer, entry)
         
         if count >= 30 then break end -- กัน UI ค้างถ้าของเยอะเกิน
      end
      Rayfield:Notify({Title = "Inventory", Content = "Loaded " .. count .. " items", Duration = 2})
   else
      Rayfield:Notify({Title = "Error", Content = "Brainrots Folder not found!", Duration = 3})
   end
end

InvTab:CreateButton({
   Name = "🔄 Refresh Inventory List",
   Callback = function()
      LoadInventory()
   end,
})

-- โหลดครั้งแรก
task.spawn(LoadInventory)

Rayfield:LoadConfiguration()
