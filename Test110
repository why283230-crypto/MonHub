local Config = { WebhookURL = "" }

-- [[ Improved Webhook Function ]]
local function SendSummaryWebhook(items, refreshTime)
    if Config.WebhookURL == "" or Config.WebhookURL == nil then 
        Rayfield:Notify({Title = "Error", Content = "ใส่ Webhook URL ใน Misc ก่อนพี่!", Duration = 3})
        return 
    end
    
    local list = ""
    if type(items) == "table" then
        for _, name in pairs(items) do list = list .. "✅ " .. name .. "\n" end
    else
        list = items -- สำหรับกรณี Test Message
    end

    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then
        Rayfield:Notify({Title = "Executor Error", Content = "ตัวรันพี่ไม่รองรับการส่ง Log (No Request Func)", Duration = 5})
        return
    end

    pcall(function()
        requestFunc({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["embeds"] = {{
                    ["title"] = "🛍️ MonHub | สรุปยอดซื้อสำเร็จ",
                    ["description"] = "รอบเวลา: **" .. refreshTime .. "**\n\n**รายการ:**\n" .. list,
                    ["color"] = 0x00ffff,
                    ["footer"] = {["text"] = "MonHub | " .. os.date("%X")}
                }}
            })
        })
    end)
end

