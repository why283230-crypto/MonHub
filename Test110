-- [[ Tab 2: Auto Buy (FORCE LOG EDITION) ]]
-- ==========================================
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)
BuyTab:CreateSection("ระบบกวาดร้านค้า (Force Log)")

BuyTab:CreateToggle({
   Name = "Auto Buy All + Force Log",
   Flag = "BuyAll_Toggle",
   Callback = function(V) 
      _G.BAll = V 
      while _G.BAll do 
         local minute = nil
         local fullTime = "00:00"
         
         -- [[ ดักจับเวลาจากหน้าจอ ]]
         for _, v in pairs(game.Players.LocalPlayer.PlayerGui:GetDescendants()) do
             if v:IsA("TextLabel") and v.Visible and v.Text:find(":") then
                 local m = v.Text:match("(%d+):")
                 if m then minute = tonumber(m); fullTime = v.Text; break end
             end
         end

         -- [[ เริ่มทำงานนาทีที่ 0 หรือ 5 ]]
         if minute and (minute % 5 == 0) then
            Rayfield:Notify({Title = "Shop Reset!", Content = "เริ่มกวาดของรอบนาทีที่ " .. minute, Duration = 3})

            -- [[ วนลูปซื้อรัวๆ ตลอด 1 นาทีเต็ม ]]
            repeat
               if not _G.BAll then break end
               for _, n in pairs(WaterfallList) do 
                  pcall(function() 
                      game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999) 
                  end) 
               end
               task.wait(2) -- ป้องกันการส่ง Request ถี่เกินไป
               
               -- อัปเดตนาทีเพื่อเช็คว่าจบนาทีหรือยัง
               local checkMin = nil
               for _, v in pairs(game.Players.LocalPlayer.PlayerGui:GetDescendants()) do
                   if v:IsA("TextLabel") and v.Visible and v.Text:find(":") then
                       local m = v.Text:match("(%d+):")
                       if m then checkMin = tonumber(m) break end
                   end
               end
            until (checkMin ~= minute) or not _G.BAll

            -- [[ พอนาทีเปลี่ยน (เช่น 05 -> 06) ให้ส่ง Log ทันที ]]
            -- รอบนี้ผมตัดการเช็คไอเทมในกระเป๋าออก เพื่อ "บังคับ" ให้มันส่ง Log ครับ
            SendSummaryWebhook("✅ ระบบได้ทำการกวาดซื้อทุกไอเทมในรายการเรียบร้อยแล้ว\n(ตรวจสอบจำนวน Block ใน Inventory ของพี่ได้เลยครับ)", "รอบนาทีที่ " .. minute .. " (" .. fullTime .. ")")
            
            task.wait(10) -- พัก 10 วินาทีเพื่อไม่ให้ลูปมันทำงานซ้อนในนาทีเดิม
         end
         task.wait(1) 
      end 
   end,
})

