-- [[ ฟังก์ชันดึงจำนวนของที่มีอยู่ปัจจุบัน ]]
local function GetCurrentAmount(itemName)
    local amount = 0
    pcall(function()
        local inv = game.Players.LocalPlayer.PlayerGui.Main.DiceContainer.Inventory.Scroll
        local itemFrame = inv:FindFirstChild(itemName)
        if itemFrame and itemFrame:FindFirstChild("Amount") then
            -- ดึงตัวเลขจาก Text เช่น "x50" -> 50
            local txt = itemFrame.Amount.Text:gsub("x", ""):gsub(",", "")
            amount = tonumber(txt) or 0
        end
    end)
    return amount
end

-- [[ Webhook Function ปรับปรุงใหม่ ]]
local function SendSummaryWebhook(reportDetails, realTime)
    if Config.WebhookURL == "" or Config.WebhookURL == nil then return end
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then return end

    pcall(function()
        requestFunc({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["embeds"] = {{
                    ["title"] = "🛍️ MonHub | สรุปยอดซื้อและคลังสินค้า",
                    ["description"] = "⏱️ เวลา: **" .. realTime .. "**\n\n" .. reportDetails,
                    ["color"] = 0xffaa00,
                    ["footer"] = {["text"] = "Inventory Sync | " .. os.date("%X")}
                }}
            })
        })
    end)
end

-- ==========================================
-- [[ Tab 2: Auto Buy (QUANTITY TRACKER) ]]
-- ==========================================
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)

BuyTab:CreateToggle({
   Name = "Auto Buy + รายละเอียดจำนวน (Real Time)",
   Flag = "BuyAll_Toggle",
   Callback = function(V) 
      _G.BAll = V 
      while _G.BAll do 
         local realMinute = tonumber(os.date("%M"))
         local realTimeStr = os.date("%X")

         if realMinute and (realMinute % 5 == 0) then
            -- 1. บันทึกจำนวนก่อนซื้อ
            local beforeBuy = {}
            for _, name in pairs(WaterfallList) do
                beforeBuy[name] = GetCurrentAmount(name)
            end
            
            Rayfield:Notify({Title = "Shop Reset!", Content = "กำลังกวาดของและเช็คจำนวน...", Duration = 3})

            -- 2. กวาดซื้อ
            repeat
               if not _G.BAll then break end
               for _, n in pairs(WaterfallList) do 
                  game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999) 
               end
               task.wait(1.5)
            until tonumber(os.date("%M")) ~= realMinute or not _G.BAll

            -- 3. บันทึกจำนวนหลังซื้อ และคำนวณผลลัพธ์
            local reportStr = "**รายการที่ได้เพิ่มในรอบนี้:**\n"
            local hasAny = false
            
            for _, name in pairs(WaterfallList) do
                local current = GetCurrentAmount(name)
                local diff = current - beforeBuy[name]
                
                if diff > 0 then
                    reportStr = reportStr .. "🔸 **" .. name .. "**: ได้เพิ่ม +" .. diff .. " (รวมมี: " .. current .. ")\n"
                    hasAny = true
                end
            end

            if not hasAny then
                reportStr = "❌ รอบนี้ไม่มีของใหม่เข้า (เงินอาจไม่พอหรือซื้อไม่ทัน)"
            end

            -- 4. ส่ง Log
            SendSummaryWebhook(reportStr, realTimeStr)
            
            task.wait(10)
         end
         task.wait(1)
      end 
   end,
})

