-- [[ ฟังก์ชัน Format & Log ]]
local function formatNumber(n)
    n = tonumber(n) or 0
    if n >= 1000000 then return string.format("%.1fm", n/1000000):gsub("%.0m", "m")
    elseif n >= 1000 then return string.format("%.1fk", n/1000):gsub("%.0k", "k")
    else return tostring(n) end
end

local function SendSummaryLog()
    if Config.WebhookURL == "" or Config.WebhookURL == nil then purchaseQueue = {}; isWaiting = false return end
    local sortedList = {}
    for name, data in pairs(purchaseQueue) do table.insert(sortedList, {Name = name, Bought = data.bought, Total = data.total}) end
    table.sort(sortedList, function(a, b) return (RarityOrder[a.Name] or 0) > (RarityOrder[b.Name] or 0) end)
    local report = ""
    for _, item in ipairs(sortedList) do report = report .. "🛒 **" .. item.Name .. "**: +" .. item.Bought .. " (รวม: `" .. formatNumber(item.Total) .. "`)\n" end
    local payload = game:GetService("HttpService"):JSONEncode({
        ["embeds"] = {{
            ["title"] = "🛍️ MonHub | รายงานกวาดซื้อ (WindUI Fixed)",
            ["description"] = report,
            ["color"] = 0x32cd32,
            ["footer"] = {["text"] = "Player: " .. game.Players.LocalPlayer.Name .. " | " .. os.date("%X")},
            ["timestamp"] = DateTime.now():ToIsoDate()
        }}
    })
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if request then request({Url = Config.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload}) end
    purchaseQueue = {}; isWaiting = false
end

-- [[ Monitor System ]]
task.spawn(function()
    while true do
        local targetFolder = game.Players.LocalPlayer:FindFirstChild("leaderstats") or game.Players.LocalPlayer:FindFirstChild("Data") or game.Players.LocalPlayer
        for _, v in ipairs(targetFolder:GetDescendants()) do
            if v:IsA("ValueBase") then
                local isTarget = false
                for _, name in pairs(WaterfallList) do if v.Name == name then isTarget = true break end end
                if isTarget and not v:GetAttribute("MonMonitored") then
                    v:SetAttribute("MonMonitored", true)
                    local lastValue = v.Value
                    v.Changed:Connect(function(newValue)
                        if v:IsDescendantOf(game.Players.LocalPlayer) and tonumber(newValue) and newValue > lastValue then
                            local diff = newValue - lastValue
                            if purchaseQueue[v.Name] then purchaseQueue[v.Name].bought = purchaseQueue[v.Name].bought + diff; purchaseQueue[v.Name].total = newValue
                            else purchaseQueue[v.Name] = {bought = diff, total = newValue} end
                            if not isWaiting then isWaiting = true; task.delay(waitTime, SendSummaryLog) end
                        end
                        lastValue = newValue
                    end)
                end
            end
        end
        task.wait(10)
    end
end)

