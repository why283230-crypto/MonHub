local WaterfallList = { "PinnacleBlock", "VerdictBlock", "HellcoreBlock", "DoomBlock", "BloodcodeBlock", "VortexBlock", "VercaBlock", "AnomalyBlock", "PhantomBlock", "CelestialEmperorBlock", "RadiantBlock", "AetherialBlock", "TheEndBlock", "KingsMantleBlock", "ToxicReactorBlock", "MoltenCoreBlock", "OuroborosBlock", "KingSunBlock", "InfinityBlock", "TimeBenderBlock", "BrambleBlock", "MagicBlock", "HeavenlyBlock", "DevilBlock", "AscendantBlock", "QuantumBlock", "GalaxyBlock", "MythicBlock", "LegendaryBlock", "EpicBlock", "RareBlock", "UncommonBlock", "CommonBlock" }
local Config = { WebhookURL = "" }

-- [[ ฟังก์ชันดึงยอดรวม (ถ้าดึงไม่ได้จะโชว์ว่า Unknown) ]]
local function GetTotal(itemName)
    local total = "N/A"
    pcall(function()
        local scroll = game.Players.LocalPlayer.PlayerGui.Main.DiceContainer.Inventory.Scroll
        if scroll:FindFirstChild(itemName) and scroll[itemName]:FindFirstChild("Amount") then
            total = scroll[itemName].Amount.Text:gsub("x", "")
        end
    end)
    return total
end

local function SendSummaryWebhook(report, realTime)
    if Config.WebhookURL == "" or Config.WebhookURL == nil then return end
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then return end

    pcall(function()
        requestFunc({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["embeds"] = {{
                    ["title"] = "🛍️ MonHub | สรุปรายการซื้อสำเร็จ",
                    ["description"] = "⏱️ เวลา: **" .. realTime .. "**\n\n" .. report,
                    ["color"] = 0x00ff00,
                    ["footer"] = {["text"] = "Confirmed Purchase | " .. os.date("%X")}
                }}
            })
        })
    end)
end

-- ==========================================
-- [[ Tab 2: Auto Buy (CONFIRMED LOG) ]]
-- ==========================================
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)

BuyTab:CreateToggle({
   Name = "Auto Buy + รายชื่อของที่ซื้อ (Real Time)",
   Flag = "BuyAll_Toggle",
   Callback = function(V) 
      _G.BAll = V 
      while _G.BAll do 
         local realMinute = tonumber(os.date("%M"))
         local realTimeStr = os.date("%X")

         if realMinute and (realMinute % 5 == 0) then
            local boughtThisRound = {} -- เก็บชื่อตัวที่ซื้อสำเร็จ
            
            Rayfield:Notify({Title = "Shop Reset!", Content = "เริ่มกวาดซื้อและบันทึกรายชื่อ...", Duration = 3})

            -- ลูปซื้อจนหมดนาที
            repeat
               if not _G.BAll then break end
               for _, n in pairs(WaterfallList) do 
                  -- ใช้ pcall เช็คการยิง Remote
                  local success = game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999)
                  if success then
                      boughtThisRound[n] = true
                  end
               end
               task.wait(1)
            until tonumber(os.date("%M")) ~= realMinute or not _G.BAll

            -- สร้างข้อความสรุป
            local reportStr = "**✅ รายการที่กวาดซื้อสำเร็จ:**\n"
            local hasItem = false
            for name, _ in pairs(boughtThisRound) do
                reportStr = reportStr .. "🔹 " .. name .. " (ยอดรวมในรหัส: " .. GetTotal(name) .. ")\n"
                hasItem = true
            end

            if not hasItem then
                reportStr = "❌ ไม่สามารถกวาดซื้อได้ (เงินอาจไม่พอสำหรับไอเทมใน List)"
            end

            SendSummaryWebhook(reportStr, realTimeStr)
            task.wait(10)
         end
         task.wait(1)
      end 
   end,
})

