-- [[ Tab 2: Auto Buy (NEW TIME LOGIC) ]]
-- ==========================================
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)
BuyTab:CreateToggle({
   Name = "Auto Buy + Summary (Reset 5 Min)",
   Flag = "BuyAll_Toggle",
   Callback = function(V) 
      _G.BAll = V 
      while _G.BAll do 
         local minute = nil
         local fullTime = "Unknown"
         
         -- [[ แก้การดึงเวลาให้แม่นยำขึ้น ]]
         for _, v in pairs(game.Players.LocalPlayer.PlayerGui:GetDescendants()) do
             if v:IsA("TextLabel") and v.Visible and v.Text:find(":") then
                 local m = v.Text:match("(%d+):")
                 if m then
                    minute = tonumber(m)
                    fullTime = v.Text
                    break
                 end
             end
         end

         -- ถ้าเข้านาทีที่ลงท้ายด้วย 0 หรือ 5
         if minute and (minute % 5 == 0) then
            local successList = {}
            local conn = game.Players.LocalPlayer.Backpack.ChildAdded:Connect(function(c) 
                table.insert(successList, c.Name) 
            end)

            Rayfield:Notify({Title = "Shop Reset!", Content = "เริ่มกวาดของในร้านแล้ว...", Duration = 3})

            -- ซื้อรัวๆ จนกว่าจะเปลี่ยนนาที
            repeat
               task.wait(0.5)
               for _, n in pairs(WaterfallList) do 
                  pcall(function() game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999) end) 
               end
               
               local checkMin = nil
               for _, v in pairs(game.Players.LocalPlayer.PlayerGui:GetDescendants()) do
                   if v:IsA("TextLabel") and v.Visible and v.Text:find(":") then
                       local m = v.Text:match("(%d+):")
                       if m then checkMin = tonumber(m) break end
                   end
               end
            until (checkMin ~= minute) or not _G.BAll

            conn:Disconnect()
            if #successList > 0 then
                SendSummaryWebhook(successList, "รอบนาทีที่ " .. tostring(minute))
            end
            task.wait(5)
         end
         task.wait(1) 
      end 
   end,
})

