local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MonHub | Block Master V10.3",
   LoadingTitle = "Real Purchase Logger...",
   LoadingSubtitle = "Only Successful Buys Will Log",
   ConfigurationSaving = { Enabled = true, FolderName = "MonHubConfigs", FileName = "BlockMaster_Save" }
})

-- [[ DATA LISTS ]]
local WaterfallList = { "PinnacleBlock", "VerdictBlock", "HellcoreBlock", "DoomBlock", "BloodcodeBlock", "VortexBlock", "VercaBlock", "AnomalyBlock", "PhantomBlock", "CelestialEmperorBlock", "RadiantBlock", "AetherialBlock", "TheEndBlock", "KingsMantleBlock", "ToxicReactorBlock", "MoltenCoreBlock", "OuroborosBlock", "KingSunBlock", "InfinityBlock", "TimeBenderBlock", "BrambleBlock", "MagicBlock", "HeavenlyBlock", "DevilBlock", "AscendantBlock", "QuantumBlock", "GalaxyBlock", "MythicBlock", "LegendaryBlock", "EpicBlock", "RareBlock", "UncommonBlock", "CommonBlock" }

local Config = { WebhookURL = "" }

-- [[ ฟังก์ชันส่ง Log เฉพาะที่ซื้อสำเร็จจริง ]]
local function SendRealBuyLog(blockName)
    if Config.WebhookURL == "" or not Config.WebhookURL:find("discord.com") then return end
    pcall(function()
        request({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["embeds"] = {{
                    ["title"] = "✅ ซื้อสำเร็จจริง! (Confirmed)",
                    ["description"] = "ได้รับไอเทม: **" .. blockName .. "**\nสถานะ: เพิ่มเข้ากระเป๋าเรียบร้อย",
                    ["color"] = 0x2ecc71, -- สีเขียวเข้ม
                    ["footer"] = {["text"] = "MonHub V10.3 | Confirmed Buy"}
                }}
            })
        })
    end)
end

-- [[ ระบบดักฟังกระเป๋า (Check if item actually added) ]]
local function StartPurchaseListener()
    local player = game.Players.LocalPlayer
    local backpack = player:WaitForChild("Backpack")
    
    backpack.ChildAdded:Connect(function(child)
        if _G.TimerBuy then -- ทำงานเฉพาะตอนเปิด Auto Buy
            for _, blockName in pairs(WaterfallList) do
                if child.Name:find(blockName) or (child:GetAttribute("EntityName") and child:GetAttribute("EntityName"):find(blockName)) then
                    SendRealBuyLog(blockName)
                    break
                end
            end
        end
    end)
end

-- ==========================================
-- [[ Tab: Auto Buy (Confirmed Edition) ]]
-- ==========================================
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)

BuyTab:CreateSection("ระบบซื้อตามเวลา (ส่งเฉพาะที่ซื้อได้)")
BuyTab:CreateToggle({
   Name = "Enable Confirmed Timer Buy",
   Flag = "TimerBuy_Toggle",
   Callback = function(Value)
      _G.TimerBuy = Value
      if Value then
          task.spawn(function()
             while _G.TimerBuy do
                local playerGui = game.Players.LocalPlayer:FindFirstChild("PlayerGui")
                local foundTime = false
                
                if playerGui then
                    for _, v in pairs(playerGui:GetDescendants()) do
                        if v:IsA("TextLabel") and v.Visible and v.Text:match("%d+:%d+") then
                            local t = v.Text
                            if t:find("^0?5:") or t:find("^0?4:") then
                                foundTime = true
                                break
                            end
                        end
                    end
                end

                if foundTime then
                    -- พยายามซื้อทุกอัน แต่ Webhook จะทำงานแค่ตัวที่ "ของเข้าตัว"
                    for _, n in pairs(WaterfallList) do
                        if not _G.TimerBuy then break end
                        pcall(function()
                            game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999)
                        end)
                    end
                    task.wait(60) -- ซื้อเสร็จรอ 1 นาทีกันซื้อซ้ำ
                end
                task.wait(1)
             end
          end)
      end
   end,
})

