-- [[ ฟังก์ชันส่งสรุป Log ]]
local function SendSummaryWebhook(items, time)
    if Config.WebhookURL == "" or #items == 0 then return end
    local list = ""
    for _, name in pairs(items) do list = list .. "✅ " .. name .. "\n" end
    
    pcall(function()
        request({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["embeds"] = {{
                    ["title"] = "🛍️ สรุปรายการซื้อสำเร็จ (Confirmed)",
                    ["description"] = "ตรวจพบเวลา: **" .. time .. "**\n\n**รายการที่ได้จริง:**\n" .. list,
                    ["color"] = 0x2ecc71,
                    ["footer"] = {["text"] = "MonHub | Summary Edition"}
                }}
            })
        })
    end)
end

