local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MonHub | Block Master V11.4",
   LoadingTitle = "Direct Inventory Access...",
   LoadingSubtitle = "Fixing N/A and Missing Items",
   ConfigurationSaving = { Enabled = true, FolderName = "MonHubConfigs", FileName = "BlockMaster_Save" }
})

local WaterfallList = { "PinnacleBlock", "VerdictBlock", "HellcoreBlock", "DoomBlock", "BloodcodeBlock", "VortexBlock", "VercaBlock", "AnomalyBlock", "PhantomBlock", "CelestialEmperorBlock", "RadiantBlock", "AetherialBlock", "TheEndBlock", "KingsMantleBlock", "ToxicReactorBlock", "MoltenCoreBlock", "OuroborosBlock", "KingSunBlock", "InfinityBlock", "TimeBenderBlock", "BrambleBlock", "MagicBlock", "HeavenlyBlock", "DevilBlock", "AscendantBlock", "QuantumBlock", "GalaxyBlock", "MythicBlock", "LegendaryBlock", "EpicBlock", "RareBlock", "UncommonBlock", "CommonBlock" }
local Config = { WebhookURL = "" }

-- [[ ฟังก์ชันดึงจำนวนจาก Inventory โดยตรง (ไม่ผ่าน UI) ]]
local function GetActualTotal(itemName)
    local total = 0
    pcall(function()
        -- พยายามดึงจากเครื่องมือในตัว (Dices/Inventory Data)
        local invData = game:GetService("ReplicatedStorage").Network.Client.GetInventory:InvokeServer()
        if invData and invData[itemName] then
            total = invData[itemName]
        end
    end)
    return total
end

local function SendSummaryWebhook(report, realTime)
    if Config.WebhookURL == "" or Config.WebhookURL == nil then return end
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then return end

    pcall(function()
        requestFunc({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["embeds"] = {{
                    ["title"] = "📦 MonHub | รายงานการกวาดซื้อถาวร",
                    ["description"] = "⏱️ รอบเวลา: **" .. realTime .. "**\n\n" .. report,
                    ["color"] = 0x5865F2,
                    ["footer"] = {["text"] = "Inventory Direct Access | " .. os.date("%X")}
                }}
            })
        })
    end)
end

-- ==========================================
-- [[ Tab 2: Auto Buy ]]
-- ==========================================
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)

BuyTab:CreateToggle({
   Name = "Auto Buy + รายละเอียดถาวร (Real Time)",
   Flag = "BuyAll_Toggle",
   Callback = function(V) 
      _G.BAll = V 
      while _G.BAll do 
         local realMinute = tonumber(os.date("%M"))
         local realTimeStr = os.date("%X")

         if realMinute and (realMinute % 5 == 0) then
            local boughtItems = {} 
            
            Rayfield:Notify({Title = "Shop Reset!", Content = "กำลังกวาดซื้อและบันทึกข้อมูล...", Duration = 3})

            -- ลูปกวาดซื้อ
            repeat
               if not _G.BAll then break end
               for _, n in pairs(WaterfallList) do 
                  local res = game:GetService("ReplicatedStorage").Network.Client.PurchaseMaxItems:InvokeServer(n, 999)
                  if res then
                      boughtItems[n] = true
                  end
               end
               task.wait(1)
            until tonumber(os.date("%M")) ~= realMinute or not _G.BAll

            -- สรุปรายการ
            local reportStr = "**✅ รายการที่กวาดซื้อสำเร็จ:**\n"
            local hasItem = false
            for name, _ in pairs(boughtItems) do
                local total = GetActualTotal(name)
                reportStr = reportStr .. "⭐ **" .. name .. "** (มีทั้งหมดในไอดี: `" .. total .. "`)\n"
                hasItem = true
            end

            if not hasItem then
                reportStr = "❌ ไม่มีการซื้อสำเร็จ (เงินไม่พอหรือของซ้ำ)"
            end

            SendSummaryWebhook(reportStr, realTimeStr)
            task.wait(10)
         end
         task.wait(1)
      end 
   end,
})

