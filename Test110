})

InvTab:CreateSection("--- My Backpack ---")
local function RefreshInvUI()
    BuildPriceMap()
    for _, v in pairs(InvLabels) do pcall(function() v:Set("") end) end
    local items = LP.Backpack:GetChildren()
    for i, item in ipairs(items) do
        if i > 20 then break end
        local entName = item:GetAttribute("EntityName") or item.Name
        local bID = item:GetAttribute("BrainrotId") or "None"
        local price = PriceDatabase[entName] or "Check Map..."
        local txt = string.format("📦 %s | 💰 %s\n🆔 ID: %s", entName, price, tostring(bID):sub(1,8))
        if InvLabels[i] then InvLabels[i]:Set(txt)
        else InvLabels[i] = InvTab:CreateLabel(txt) end
    end
end

InvTab:CreateButton({
   Name = "🔄 Refresh Price & List",
   Callback = function() RefreshInvUI() end,
})

